      {name:'parse_pdf()',desc:'pdfplumber 合同文本抽取与版面还原'},
      {name:'gpt4o_extract()',desc:'GPT-4o Structured Output strict=True，强制 JSON 输出'},
      {name:'compute_sha256()',desc:'hashlib.sha256 真实哈希计算（非硬编码）'},
      {name:'write_evidence()',desc:'Chain of Custody 七字段日志写入证据库'},
    ],
    inputSchema:`{
