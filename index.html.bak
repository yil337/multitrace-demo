        <div class="hrc-hyp-label">H2 市场价格紧缺</div>
        <div class="hrc-bar-wrap">
          <div class="hrc-bar"><div class="hrc-bar-fill" style="width:25%"></div></div>
          <span class="hrc-pct">25%</span>
        </div>
      </div>
      <div class="hrc-hyp hrc-h3" style="margin-top:6px">
        <div class="hrc-hyp-label">H3 张建国被欺骗</div>
        <div class="hrc-bar-wrap">
          <div class="hrc-bar"><div class="hrc-bar-fill" style="width:10%"></div></div>
          <span class="hrc-pct">10%</span>
        </div>
      </div>
    </div>

