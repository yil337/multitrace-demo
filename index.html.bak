/* ─────────────── Step 8 — 交叉印证 ─────────────── */
8: () => `
<div class="step-section">
  <div class="step-section-title">🔐 三源独立性声明（最高检 2016 电子数据规定）</div>
  <div style="background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:14px 16px;margin:8px 0;font-size:12px;line-height:1.8">
    <div style="margin-bottom:8px;display:grid;grid-template-columns:80px 1fr;gap:8px">
      <span style="font-weight:700;color:var(--blue)">证据线 A</span>
      <span style="color:var(--t2)">通讯证据：邮件 E018 / E028 / E035 — 来源：<code style="font-size:10px;background:var(--bg3);padding:1px 4px;border-radius:3px">email_server</code>（SMTP 日志独立存储，与 ERP 物理隔离）</span>
    </div>
    <div style="margin-bottom:8px;display:grid;grid-template-columns:80px 1fr;gap:8px">
      <span style="font-weight:700;color:var(--green)">证据线 B</span>
      <span style="color:var(--t2)">合同财务：contracts.json + goods_receipts.json — 来源：<code style="font-size:10px;background:var(--bg3);padding:1px 4px;border-radius:3px">ERP + WMS</code>（两套独立系统，双写日志）</span>
    </div>
    <div style="margin-bottom:10px;display:grid;grid-template-columns:80px 1fr;gap:8px">
      <span style="font-weight:700;color:var(--amber)">证据线 C</span>
      <span style="color:var(--t2)">IT 日志：logs.json L010 / L020 / L023 — 来源：<code style="font-size:10px;background:var(--bg3);padding:1px 4px;border-radius:3px">network_security_device</code>（与 ERP 物理隔离）</span>
    </div>
    <div style="padding-top:10px;border-top:1px dashed var(--border);font-size:11px;color:var(--t3)">
      ✓ <strong>独立性验证</strong>：三条证据线来源系统无共享数据库，排除单一数据篡改导致三线同时变化的可能。<br>
      📜 法律依据：<strong>《监察法》第40条</strong>——"形成相互印证、完整稳定的证据链"；最高检 2016 电子数据规定"相互印证"原则。
    </div>
  </div>
</div>

<div class="step-section">
  <div class="step-section-title">🧩 交叉印证矩阵（3 异常事件 × 3 证据线）</div>
  <div class="step-table-wrap">
    <table class="step-table">
      <thead>
        <tr>
          <th>异常事件</th>
          <th>A — 通讯证据</th>
          <th>B — 合同财务</th>
          <th>C — IT 日志</th>
          <th>印证等级</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>利益关联建立</strong><div style="font-size:10px;color:var(--t4)">深夜私下沟通</div></td>
          <td><span class="cv-chip cv-yes">✓ E018</span></td>
          <td><span class="cv-chip cv-no">— 无直接记录</span></td>
          <td><span class="cv-chip cv-yes">✓ L010 同期境外VPN</span></td>
          <td><span class="verify-2">双线印证</span></td>
        </tr>
        <tr class="td-hi">
          <td><strong>C-2024-089 异常</strong><div style="font-size:10px;color:var(--t4)">付款¥234万 / 155天零收货</div></td>
          <td><span class="cv-chip cv-yes">✓ E028 付款确认</span></td>
          <td><span class="cv-chip cv-yes">✓ 零收货 已付¥234万</span></td>
          <td><span class="cv-chip cv-yes">✓ L023 审计前下载</span></td>
          <td><span class="verify-3">⚠ 三线印证</span></td>
        </tr>
        <tr>
          <td><strong>审计应对行为</strong><div style="font-size:10px;color:var(--t4)">内审通知后次日</div></td>
          <td><span class="cv-chip cv-yes">✓ E035 暂停通知</span></td>
          <td><span class="cv-chip cv-no">— 无直接记录</span></td>
          <td><span class="cv-chip cv-yes">✓ L020 127件删除</span></td>
          <td><span class="verify-2">双线印证</span></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<div class="step-section">
  <div class="step-section-title">🧮 置信度综合计算（算法引擎，非 LLM）</div>
  <div class="conf-calc-box">
    <div class="ccb-title">⚙ Confidence Aggregation — ACFE 证据优先级框架（近似估算）</div>
    <div class="conf-calc-row">
      <span class="ccr-label">A — 通讯证据</span>
      <span class="ccr-formula">0.90 × 35%</span>
      <span class="ccr-eq">=</span>
      <span class="ccr-val">0.315</span>
    </div>
    <div class="conf-calc-row">
      <span class="ccr-label">B — 合同财务</span>
      <span class="ccr-formula">0.95 × 40%</span>
      <span class="ccr-eq">=</span>
      <span class="ccr-val">0.380</span>
    </div>
    <div class="conf-calc-row">
      <span class="ccr-label">C — IT 日志</span>
      <span class="ccr-formula">0.88 × 25%</span>
      <span class="ccr-eq">=</span>
      <span class="ccr-val">0.220</span>
    </div>
    <div class="conf-calc-total">
      <span>综合置信度</span>
      <span>0.315 + 0.380 + 0.220</span>
      <span>=</span>
      <span class="cct-result">92%</span>
    </div>
    <div class="ccb-note">
      📐 <strong>权重推导逻辑</strong>（参照 ACFE FEM 2022 Evidence Hierarchy + 本案数据完整性评估）：<br>
      • B线 40%：ERP合同+WMS收货系统双写，数据最完整可核查<br>
      • A线 35%：SMTP服务器独立存储，可提取元数据，次之<br>
      • C线 25%：网络设备日志，技术门槛高，可信但较难解读<br>
      • 单线得分（0.90/0.95/0.88）= 各线证据内部一致性 × 可核查性评分<br>
      ⚠ 此为主观赋权近似估算，非统计验证公式。直接资金流（银行流水）尚未获取，置信度留有进一步提升空间 ⓘ
    </div>
  </div>
</div>

<div class="mbadge-wrap">
  ${mb('blue','🔗 三线印证','Step 8','最高检2016电子数据规定','C-2024-089 三源独立印证 — 最高印证等级')}
  ${mb('blue','🔗 双线印证','Step 8','最高检2016电子数据规定','利益关联建立 + 审计应对行为（各双线）')}
  ${mb('blue','⚙ 置信度计算','Step 8','ACFE证据优先级框架','0.315 + 0.380 + 0.220 = 92%')}
</div>

<div class="step8-bridge">
  <div class="step8-bridge-icon">⚙→⏸</div>
  <div>
    <strong style="color:var(--t1)">Tier 3 全自动完成</strong> · 置信度综合计算输出 <strong style="color:var(--green)">92%</strong>，证据矩阵已锁定。<br>
    <span style="color:var(--purple)"><strong>下一节点：Step 9 — HITL Tier 2 专业判断确认</strong></span><br>
    假设验证官已完成三轮分析，正在等待调查员做出最终假设判断 →
    <button onclick="goStep(9)" style="margin-left:8px;background:var(--purple);color:#fff;border:none;border-radius:6px;padding:4px 14px;font-size:11px;font-weight:700;cursor:pointer">前往 Step 9 ▶</button>
  </div>
</div>`,

/* ─────────────── Step 9 — 假设驱动分析 ─────────────── */
9: () => `
<div class="step-section">
  <div class="step-section-title">🔬 三轮 Fraud Theory Approach 迭代（ACFE FEM 2022 Fraud Theory Approach）</div>
  <div class="hyp-stepper">

    <div class="hyp-round-card">
      <div class="hrc-badge hrc-r1">Round 1 / 3</div>
      <div class="hrc-input">💭 输入：立案线索 + 图谱关系<br>GPT-4o 调用 #1 — 初始假设生成（含 ≥1 无辜假设）</div>
      <div class="hrc-hyp hrc-h1">
        <div class="hrc-hyp-label">H1 利益输送协议</div>
