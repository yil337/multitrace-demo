/* ──────────── HITL Step 1 Approve ──────────── */
function approveStep1() {
  const box = document.getElementById('hitl-step1-box');
  const btn = document.getElementById('hitl-step1-btn');
  if (!box || !btn) return;
  btn.disabled = true;
  btn.textContent = '✓ 已授权 — INV-2024-0847 正式立案';
  box.classList.add('approved');
  box.querySelector('.hitl-approve-title').textContent = '✓ 立案授权完成 — 总指挥路由至 Step 2';
  showToast('✅', '审计主任授权立案。总指挥 Agent 正在路由至 Step 2 证据保全…');
  setTimeout(() => goStep(2), 1600);
}

/* ──────────── HITL Step 12 Final Approve ──────────── */
function approveStep12() {
  const box = document.getElementById('hitl-step12-box');
  const btn = document.getElementById('hitl-step12-btn');
  if (!box || !btn) return;
  btn.disabled = true;
  btn.textContent = '✓ 已授权 — 处置方案执行中';
  box.classList.add('approved');
  box.querySelector('.hitl-approve-title').textContent = '✓ 审计委员会授权完成 — INV-2024-0847 进入处置执行阶段';
  showToast('✅', '审计委员会主席已授权。MultiTrace 正在生成最终报告并触发纪律处分流程…');
  setTimeout(() => {
    showToast('📄', '最终报告 INV-2024-0847-FINAL.pdf 已生成并归档至证据链 (EV-REPORT-001)');
  }, 2000);
}

/* ══════════════════════════════════════════════
   STAGE 7 — vis.js Knowledge Graph (Step 6)
══════════════════════════════════════════════ */
let _visNetwork = null;
let _visLayoutMode = 'hierarchical';

function initVisGraph() {
  const container = document.getElementById('vis-network-container');
  if (!container) return;
  if (typeof vis === 'undefined') { setTimeout(initVisGraph, 400); return; }

  const isDark = document.documentElement.dataset.theme === 'dark';
  const bg   = isDark ? '#1a2035' : '#f8fafc';
  const text  = isDark ? '#cbd5e1' : '#1e293b';

  const nodes = new vis.DataSet([
    {id:1, label:'张建国\n采购经理',      group:'risk',     title:'工号:USR-001 | 风险:HIGH | 关联合同:3份 | 深夜VPN异常'},
    {id:2, label:'陈志远\n审批主任',      group:'risk',     title:'审批合同2份 | 审批链全程参与'},
    {id:3, label:'赵雪\n法务审核',        group:'normal',   title:'法务审核员 | 合同法律审查'},
    {id:4, label:'王磊\nABC电子法人',     group:'risk',     title:'ABC电子科技法人代表 | 与张建国23次通话'},
    {id:5, label:'ABC电子科技\n有限公司', group:'company',  title:'统一信用代码:91XXXXXXXX\n3份合同总额:¥735万\n3份均高价偏离≥38%'},
    {id:6, label:'C-2024-089\n¥234万',   group:'contract', title:'12.67σ偏离 | 零收货155天+ | 已付款'},
    {id:7, label:'C-2024-156\n¥189万',   group:'contract', title:'14.42σ偏离 | 逆序收货21天 | 已付款'},
    {id:8, label:'C-2024-287\n¥312万',   group:'contract', title:'12.42σ偏离 | 谈判中（内审后暂停）'},
  ]);

  const edges = new vis.DataSet([
    {id:1,  from:1, to:6, label:'SIGNED',          arrows:'to', color:{color:'#dc2626'}, width:2},
    {id:2,  from:1, to:7, label:'SIGNED',          arrows:'to', color:{color:'#dc2626'}, width:2},
    {id:3,  from:1, to:8, label:'SIGNED',          arrows:'to', color:{color:'#dc2626'}, width:2},
    {id:4,  from:2, to:6, label:'APPROVED',        arrows:'to', color:{color:'#d97706'}},
    {id:5,  from:2, to:7, label:'APPROVED',        arrows:'to', color:{color:'#d97706'}},
    {id:6,  from:3, to:6, label:'LEGAL_REVIEW',    arrows:'to', color:{color:'#94a3b8'}},
    {id:7,  from:3, to:7, label:'LEGAL_REVIEW',    arrows:'to', color:{color:'#94a3b8'}},
    {id:8,  from:4, to:5, label:'REPRESENTS',      arrows:'to', color:{color:'#2563eb'}, width:2},
    {id:9,  from:5, to:6, label:'PARTY_B',         arrows:'to', color:{color:'#7c3aed'}},
    {id:10, from:5, to:7, label:'PARTY_B',         arrows:'to', color:{color:'#7c3aed'}},
    {id:11, from:5, to:8, label:'PARTY_B',         arrows:'to', color:{color:'#7c3aed'}},
    {id:12, from:1, to:4, label:'COMMUNICATED\n×23次', arrows:'to', dashes:true,
            color:{color:'#dc2626'}, width:3, font:{color:'#dc2626',size:9}},
  ]);

  const groupColors = {
    risk:     {bg:isDark?'#3f1515':'#fef2f2', border:'#dc2626', hbg:isDark?'#5a1a1a':'#fee2e2', hb:'#b91c1c', font:isDark?'#fca5a5':'#991b1b'},
    normal:   {bg:isDark?'#1e2535':'#f8fafc', border:'#94a3b8', hbg:isDark?'#253047':'#f1f5f9', hb:'#64748b', font:isDark?'#94a3b8':'#475569'},
    company:  {bg:isDark?'#0f1e3a':'#eff6ff', border:'#2563eb', hbg:isDark?'#1a2e4a':'#dbeafe', hb:'#1d4ed8', font:isDark?'#93c5fd':'#1e40af'},
    contract: {bg:isDark?'#1a0e35':'#f5f3ff', border:'#7c3aed', hbg:isDark?'#261545':'#ede9fe', hb:'#6d28d9', font:isDark?'#c4b5fd':'#5b21b6'},
  };

  const groups = {};
  Object.entries(groupColors).forEach(([k,v]) => {
    groups[k] = {
      color:{background:v.bg, border:v.border, highlight:{background:v.hbg, border:v.hb}},
      font:{color:v.font, size:12, face:'Inter,sans-serif'},
      shape:'box', borderWidth:2,
      shadow:{enabled:true,size:4,x:1,y:2},
    };
  });

  const options = {
    nodes:{margin:8},
    groups,
    edges:{
      font:{size:9, color:text, align:'middle', background:bg, strokeWidth:0},
      smooth:{type:'cubicBezier', forceDirection:'none', roundness:0.5},
    },
    layout:{hierarchical:{enabled:true, direction:'LR', sortMethod:'hubsize',
      levelSeparation:160, nodeSpacing:90, blockShifting:true}},
    interaction:{hover:true, tooltipDelay:150, navigationButtons:false, keyboard:false},
    physics:{enabled:false},
  };

  if (_visNetwork) { _visNetwork.destroy(); _visNetwork = null; }
  _visNetwork = new vis.Network(container, {nodes, edges}, options);
}

function setVisLayout(mode) {
  _visLayoutMode = mode;
  document.querySelectorAll('.vis-layout-btn').forEach(b => b.classList.remove('vl-active'));
  const map = {hierarchical:'vis-btn-hier', physics:'vis-btn-phys', risk:'vis-btn-risk'};
  const btn = document.getElementById(map[mode]);
  if (btn) btn.classList.add('vl-active');
  if (!_visNetwork) return;
  if (mode === 'hierarchical') {
    _visNetwork.setOptions({layout:{hierarchical:{enabled:true,direction:'LR',sortMethod:'hubsize',levelSeparation:160}}, physics:{enabled:false}});
  } else if (mode === 'physics') {
    _visNetwork.setOptions({layout:{hierarchical:{enabled:false}}, physics:{enabled:true, barnesHut:{gravitationalConstant:-3000,centralGravity:0.3,springLength:160}}});
    setTimeout(()=>_visNetwork&&_visNetwork.setOptions({physics:{enabled:false}}), 2200);
  } else if (mode === 'risk') {
    _visNetwork.setOptions({layout:{hierarchical:{enabled:false}}, physics:{enabled:true, barnesHut:{gravitationalConstant:-6000,centralGravity:0.9,springLength:120}}});
    setTimeout(()=>_visNetwork&&_visNetwork.setOptions({physics:{enabled:false}}), 2200);
  }
}

/* ──────────── caseInit ──────────── */
let _caseInited = false;
function caseInit() {
  if (!_caseInited) {
    renderSpine();
    _caseInited = true;
  }
  goStep(currentStep);
}

/* ══════════════════════════════════════════════
   STAGE 10 — Polish & Animations
══════════════════════════════════════════════ */

/* Count-up number animation */
function countUp(el, target, duration, decimals, prefix, suffix) {
  if (!el) return;
  const t0 = performance.now();
  (function tick(now) {
    const p = Math.min(1, (now - t0) / duration);
    const ease = 1 - Math.pow(1 - p, 3); // cubic ease-out
    const val = target * ease;
    el.textContent = (prefix || '') + val.toFixed(decimals || 0) + (suffix || '');
    if (p < 1) requestAnimationFrame(tick);
  })(t0);
}

/* Inject agent layer fake processing bar */
function injectAgentBar() {
  const al = document.querySelector('.agent-layer');
  if (!al) return;
  const wrap = document.createElement('div');
  wrap.className = 'al-prog-wrap';
  const bar  = document.createElement('div');
  bar.className = 'al-prog-bar';
  wrap.appendChild(bar);
  al.appendChild(wrap);
  // Fade out after animation completes, then remove
  setTimeout(() => bar.classList.add('done'), 540);
  setTimeout(() => wrap.remove(), 820);
}

/* Animate hypothesis confidence bars in Step 9 (reset to 0, then restore) */
function triggerHypBars() {
  const fills = document.querySelectorAll('.hrc-bar-fill');
  fills.forEach(el => {
    const target = el.style.width || '0%';
    el.style.width = '0%';
    requestAnimationFrame(() => requestAnimationFrame(() => {
      el.style.width = target;
    }));
  });
}

/* Animate price deviation bar chart (Step 7) */
function animatePriceChart() {
  document.querySelectorAll('#price-bar-chart .pbc-market-fill, #price-bar-chart .pbc-excess-fill').forEach(el => {
    const target = el.dataset.w;
    if (!target) return;
    el.style.width = '0';
    requestAnimationFrame(() => requestAnimationFrame(() => { el.style.width = target; }));
  });
}

/* Animate behavioral anomaly bar chart (Step 7) */
function animateBehavChart() {
  document.querySelectorAll('#behav-bar-chart .bbc-baseline, #behav-bar-chart .bbc-anomaly').forEach(el => {
    const target = el.dataset.w;
    if (!target) return;
    el.style.width = '0';
    requestAnimationFrame(() => requestAnimationFrame(() => { el.style.width = target; }));
  });
}

/* Animate σ values in Step 7 */
function animateSigmaCards() {
  const cards = document.querySelectorAll('.sigma-card-val');
  const targets = [12.67, 14.42, 12.42];
  cards.forEach((el, i) => {
    if (targets[i] !== undefined) countUp(el, targets[i], 750, 2, '', 'σ');
  });
}

/* Animate financial cards in Step 11 */
function animateFinancials() {
  const cards = document.querySelectorAll('.fib-val');
  const cfg = [{t:64.3,d:1},{t:54,d:0},{t:118,d:0}];
  cards.forEach((el, i) => {
    if (cfg[i]) countUp(el, cfg[i].t, 700, cfg[i].d, '¥', '万');
  });
}

/* Animate confidence gauge (right sidebar, once on case view open) */
function animateConfGauge() {
  const val  = document.querySelector('.conf-gauge-val');
  const fill = document.querySelector('.conf-bar-fill');
  if (val)  countUp(val, 92, 900, 0, '', '%');
  if (fill) {
    fill.style.width = '0%';
    requestAnimationFrame(() => requestAnimationFrame(() => {
      fill.style.width = '92%';
    }));
  }
}

/* ── Hypothesis Selection State ── */
let _hypState = { selected: null, confirmed: false };

function selectHypothesis(el, hyp) {
  if (_hypState.confirmed) return; // locked after confirmation
  _hypState.selected = hyp;

  // Update card visual states
  document.querySelectorAll('.hyp-sel-card').forEach(c => {
    c.classList.remove('selected', 'rejected');
    if (c !== el) c.classList.add('rejected');
  });
  el.classList.add('selected');

  // Build summary text
  const meta = {
    H1: { name:'H1 — 利益输送协议', conf:'92%', color:'var(--green)' },
    H2: { name:'H2 — 市场价格紧缺', conf:'5%',  color:'var(--red)'   },
    H3: { name:'H3 — 张建国被欺骗', conf:'3%',  color:'var(--red)'   }
  };
  const m = meta[hyp];
  const summary = document.getElementById('hyp-selected-summary');
  if (summary) summary.innerHTML =
    `您已选择：<strong>${m.name}</strong>（AI置信度 <strong style="color:${m.color}">${m.conf}</strong>）<br>
     确认后，AI 将以此假设为基础生成 Step 10 访谈问题包与最终处置建议`;

  const wrap = document.getElementById('hyp-confirm-wrap');
  if (wrap) wrap.style.display = 'block';
}

function confirmHypothesis() {
  if (!_hypState.selected) return;
  _hypState.confirmed = true;

  const names = { H1:'H1 — 利益输送协议', H2:'H2 — 市场价格紧缺', H3:'H3 — 张建国被欺骗' };

  // Lock cards
  document.querySelectorAll('.hyp-sel-card').forEach(c => c.classList.add('locked'));

  // Swap confirm button → confirmed state
  const wrap = document.getElementById('hyp-confirm-wrap');
  if (wrap) wrap.style.display = 'none';
  const nameEl = document.getElementById('hcs-hypothesis-name');
  if (nameEl) nameEl.textContent = names[_hypState.selected];
  const confirmed = document.getElementById('hyp-confirmed-state');
  if (confirmed) confirmed.style.display = 'block';
}

function _restoreHypState() {
  if (!_hypState.confirmed || !_hypState.selected) return;
  const el = document.getElementById('hyp-card-' + _hypState.selected.toLowerCase());
  if (el) {
    document.querySelectorAll('.hyp-sel-card').forEach(c => {
      c.classList.remove('selected', 'rejected');
      c.classList.add('locked');
      if (c !== el) c.classList.add('rejected');
    });
    el.classList.add('selected');
  }
  const wrap = document.getElementById('hyp-confirm-wrap');
  if (wrap) wrap.style.display = 'none';
  const names = { H1:'H1 — 利益输送协议', H2:'H2 — 市场价格紧缺', H3:'H3 — 张建国被欺骗' };
  const nameEl = document.getElementById('hcs-hypothesis-name');
  if (nameEl) nameEl.textContent = names[_hypState.selected];
  const confirmed = document.getElementById('hyp-confirmed-state');
  if (confirmed) confirmed.style.display = 'block';
}

/* Per-step post-render orchestrator */
function postRenderHooks(n) {
  injectAgentBar();
  if (n === 7) {
    setTimeout(animateSigmaCards, 120);
    setTimeout(animatePriceChart, 200);
    setTimeout(animateBehavChart, 300);
  }
  if (n === 9) {
    setTimeout(triggerHypBars, 80);
    setTimeout(_restoreHypState, 150); // restore confirmed state if returning
  }
  if (n === 11) setTimeout(animateFinancials, 120);
}

/* ══════════════════════════════════════════════
   INIT
══════════════════════════════════════════════ */
(function init(){
  showToast('✅','MultiTrace V3 已就绪 — 7 Agent LangGraph · 12步调查框架 · 示例案件 INV-2024-0847');
  // Initial org chart draw after layout settles
  setTimeout(drawOrgChart, 200);
})();
</script>
</body>
</html>
