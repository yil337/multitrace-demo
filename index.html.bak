];

let currentStep = 1;

/* ──────────── Agent 元数据（供 chip 显示用）──────────── */
const AGENT_META_SLIM = {
  orchestrator: { icon:'🎯', name:'总指挥',    num:'Agent 0', color:'var(--blue)',   layerClass:'layer-orchestration' },
  doc_intel:    { icon:'📄', name:'文档情报官', num:'Agent 1', color:'var(--amber)',  layerClass:'layer-intel'         },
  entity:       { icon:'🕸️', name:'实体图谱官', num:'Agent 2', color:'var(--amber)',  layerClass:'layer-intel'         },
  statistical:  { icon:'📊', name:'统计核查官', num:'Agent 3', color:'var(--red)',    layerClass:'layer-analysis'      },
  behavioral:   { icon:'👤', name:'行为画像官', num:'Agent 4', color:'var(--red)',    layerClass:'layer-analysis'      },
  hypothesis:   { icon:'🔬', name:'假设验证官', num:'Agent 5', color:'var(--purple)', layerClass:'layer-synthesis'     },
  reporter:     { icon:'📋', name:'合规报告官', num:'Agent 6', color:'var(--green)',  layerClass:'layer-output'        },
};

/* ──────────── renderSpine ──────────── */
function renderSpine() {
  const list = document.getElementById('spine-list');
  if (!list) return;
  list.innerHTML = STEPS.map(s => {
    const icon = s.status === 'completed' ? '✓'
                : s.status === 'active'    ? '▶'
                : String(s.id);
    return `<div class="spine-step spine-${s.status}" onclick="goStep(${s.id})" id="spine-s${s.id}">
      <div class="spine-num spine-num-${s.status}">${icon}</div>
      <div class="spine-label">
        <div class="spine-label-main">${s.short}</div>
        <div class="spine-label-sub">Step ${s.id}</div>
      </div>
    </div>`;
  }).join('');
}

/* ──────────── renderStep ──────────── */
function renderStep(n) {
  const s = STEPS.find(x => x.id === n);
  if (!s) return;
  const main = document.getElementById('case-main');
  if (!main) return;

  // Breadcrumb
  const crumb = document.getElementById('crumb-step');
  if (crumb) crumb.textContent = `Step ${s.id} — ${s.name}`;

  // HITL badge
  const hitlMap = {
    1: { cls:'hitl-1', text:'⏸ Tier 1 必须人工审批' },
    2: { cls:'hitl-2', text:'👁 Tier 2 事后复核'    },
    3: { cls:'hitl-3', text:'⚙ Tier 3 全自动'       },
  };
  const hb = hitlMap[s.hitl] || hitlMap[3];

  // Status pill
  const statusPill = s.status === 'completed'
    ? `<span class="step-status-pill pill-completed">✓ 已完成</span>`
    : s.status === 'active'
    ? `<span class="step-status-pill pill-active">▶ 进行中</span>`
    : `<span class="step-status-pill pill-pending">○ 待执行</span>`;

  // Agent Layer chips
  const agentChips = s.agents.map(aid => {
    const m = AGENT_META_SLIM[aid];
    if (!m) return '';
    return `<div class="agent-chip ${m.layerClass}" onclick="openAgentModal('${aid}')">
      <span class="agent-chip-icon">${m.icon}</span>
      <div class="agent-chip-info">
        <div class="agent-chip-name">${m.name}</div>
        <div class="agent-chip-num">${m.num}</div>
      </div>
      <span class="agent-chip-arrow">↗</span>
    </div>`;
  }).join('');

  main.innerHTML = `
<div class="step-head">
  <div class="step-head-left">
    <div class="step-head-num">Step ${s.id}</div>
    <div class="step-head-info">
      <div class="step-head-name">${s.name}</div>
      <div class="step-head-sub">${s.subtitle}</div>
    </div>
  </div>
  <div class="step-head-right">
    ${statusPill}
    <span class="hitl-badge ${hb.cls}" style="font-size:10px">${hb.text}</span>
  </div>
</div>

<div class="agent-layer">
  <div class="agent-layer-label">🤖 执行 Agent</div>
  <div class="agent-layer-chips">${agentChips}</div>
  <div class="agent-layer-hint">点击 Agent 卡片查看完整能力 →</div>
</div>

<div class="step-body">
  ${getStepBody(s.id)}
</div>

<div class="step-nav">
  ${n > 1
    ? `<button class="step-nav-btn" onclick="goStep(${n-1})">← Step ${n-1}</button>`
    : `<span></span>`}
  <span class="step-nav-info">Step ${n} / 12</span>
  ${n < 12
    ? `<button class="step-nav-btn step-nav-next" onclick="goStep(${n+1})">Step ${n+1} →</button>`
    : `<span></span>`}
</div>`;
  // Post-render hooks
  if (n === 6) setTimeout(initVisGraph, 120);
  setTimeout(() => postRenderHooks(n), 20);
}

/* ──────────── goStep ──────────── */
function goStep(n) {
  currentStep = n;
  // Dynamically update step statuses: all before n = completed, n = active, after n = pending
  STEPS.forEach(s => {
    if (s.id < n)      s.status = 'completed';
    else if (s.id === n) s.status = 'active';
    else                 s.status = 'pending';
  });
  renderSpine(); // Re-render spine to reflect updated statuses
  renderStep(n);
  // Scroll to top of case main on step change
  const cm = document.getElementById('case-main');
  if (cm) cm.scrollTop = 0;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

/* ══════════════════════════════════════════════
   STAGE 6-7 — Step body content (Steps 1-6)
══════════════════════════════════════════════ */

/* Methodology badge helper */
function mb(color, ...parts) {
  const inner = parts.map((p,i) => {
    if (i === 0) return `<span>${p}</span>`;
    if (i === parts.length-1) return `<span class="mb-sep">|</span><span class="mb-val">${p}</span>`;
    return `<span class="mb-sep">|</span><span>${p}</span>`;
  }).join('');
  return `<div class="mbadge mbadge-${color}">${inner}</div>`;
}

/* Default placeholder for steps not yet implemented */
function _stepPlaceholder(n) {
  return `<div class="step-placeholder">
    <div class="step-placeholder-icon">🔬</div>
    <div class="step-placeholder-title">Step ${n} 内容将在后续 Stage 中接入</div>
    <div class="step-placeholder-sub">详细分析数据、可视化与 Methodology Badge 即将填充</div>
  </div>`;
}

/* Step body dispatcher */
function getStepBody(n) {
  return (STEP_BODY_FNS[n] || (() => _stepPlaceholder(n)))();
}

const STEP_BODY_FNS = {

/* ─────────────── Step 1 — 立案评估 ─────────────── */
