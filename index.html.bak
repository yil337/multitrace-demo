      {name:'generate_section()',desc:'GPT-4o 生成报告章节，强制 SSFS No.1 风格'},
      {name:'ssfs_check()',desc:'扫描并自动替换 SSFS No.1 禁用语言'},
      {name:'ev_link()',desc:'将结论段落链接至 EV-ID + SHA-256 + 文件路径'},
