    interactions:[
      {dir:'in', text:'接收 假设验证官(Agent 5) 的 hypothesis_package（92% 置信度 + 完整 EV-ID 证据链）'},
      {dir:'out',text:'输出最终调查报告（PDF）至 总指挥(Agent 0) Step 12 移交节点'},
      {dir:'out',text:'输出访谈问题包至调查团队，对应张建国三轮问话策略'},
    ],
  },
};

/* ── Modal Rendering Helpers ── */
function _tagline(d){
  const c=d.color||'var(--blue)';
  return `<div class="m-tagline" style="border-left-color:${c}">${d.tagline}</div>`;
}
function _abilities(list){
  return `<div class="m-abilities">${list.map(a=>`
    <div class="m-ability">
      <div class="m-ability-dot"></div>
      <span>${a.text}${a.cite?`<span class="m-ability-cite">[${a.cite}]</span>`:''}</span>
    </div>`).join('')}</div>`;
}
function _react(steps){
  return `<div class="react-log">${steps.map(s=>`
    <div class="react-step rs-${s.type}">
      <div class="react-step-head">${s.label}</div>
      <div class="react-step-body">${s.text}</div>
    </div>`).join('')}</div>`;
}
function _stepBadges(steps){
  return `<div class="step-badge-list">${steps.map(s=>`<span class="step-badge">${s}</span>`).join('')}</div>`;
}
function _tools(tools){
  return `<div class="tool-list">${tools.map(t=>`
    <div class="tool-item">
      <code>${t.name}</code>
      <span class="tool-desc">${t.desc}</span>
    </div>`).join('')}</div>`;
}
function _schema(code,label){
  return `<div class="schema-label">${label}</div><div class="schema-box">${code}</div>`;
}
function _hitl(h){
  const cls=h.tier===1?'hitl-1-box':h.tier===2?'hitl-2-box':'hitl-3-box';
  return `<div class="hitl-explain-box ${cls}">
    <div class="hitl-explain-title">${h.title}</div>
    <div>${h.desc}</div>
  </div>`;
}
function _interactions(items){
  return `<div class="interact-list">${items.map(i=>`
    <div class="interact-item">
      <span class="interact-dir ${i.dir==='in'?'interact-in':'interact-out'}">${i.dir==='in'?'← 接收':'→ 输出'}</span>
      <span class="interact-text">${i.text}</span>
    </div>`).join('')}</div>`;
}

function buildModalBody(agentId){
  const d=AGENT_CONTENT[agentId];
  if(!d) return `<div style="padding:48px;text-align:center;color:var(--t3)">暂无内容</div>`;
  return `
<div class="modal-2col">
  <!-- ── 左列 60% ── -->
  <div class="m-left">
    ${_tagline(d)}
    <div class="m-section">
      <div class="m-section-title">🧩 核心能力</div>
      ${_abilities(d.abilities)}
    </div>
    <div class="m-section">
      <div class="m-section-title">🔄 ReAct 推理示例 <small>— 案例 INV-2024-0847 真实执行片段</small></div>
      ${_react(d.react)}
    </div>
    <div class="m-section">
      <div class="m-section-title">🔗 Agent 协作接口</div>
      ${_interactions(d.interactions)}
    </div>
  </div>
  <!-- ── 右列 40% ── -->
  <div class="m-right">
    <div class="m-section">
      <div class="m-section-title">📍 负责步骤</div>
      ${_stepBadges(d.steps)}
    </div>
    <div class="m-section">
      <div class="m-section-title">🛠 工具列表（MCP + 内置）</div>
      ${_tools(d.tools)}
    </div>
    <div class="m-section">
      <div class="m-section-title">📋 I/O JSON Schema</div>
      ${_schema(d.inputSchema,'输入')}
      <div style="height:8px"></div>
      ${_schema(d.outputSchema,'输出')}
    </div>
    <div class="m-section">
      <div class="m-section-title">👤 HITL 控制层级</div>
      ${_hitl(d.hitl)}
    </div>
  </div>
</div>
<!-- ── 底部 CTA ── -->
<div class="modal-footer">
  <span class="modal-footer-info">
    <span class="tag tag-blue" style="font-size:9px">7-Agent LangGraph</span>
    <span>INV-2024-0847 · MultiTrace V3</span>
  </span>
  <button class="btn btn-primary" onclick="closeAgentModal();showView('case')" style="font-size:12px;padding:7px 16px">
    查看此 Agent 在案例中的表现 →
  </button>
</div>`;
}

