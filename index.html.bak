          <div class="conf-gauge-label">综合置信度（三源加权）</div>
          <div class="conf-bar"><div class="conf-bar-fill" style="width:92%"></div></div>
          <div class="conf-sources">
            <div class="conf-source"><span style="display:flex;align-items:center"><span class="conf-source-dot" style="background:var(--blue)"></span>通信证据</span><span>0.90 × 35%</span></div>
            <div class="conf-source"><span style="display:flex;align-items:center"><span class="conf-source-dot" style="background:var(--red)"></span>合同财务</span><span>0.95 × 40%</span></div>
            <div class="conf-source"><span style="display:flex;align-items:center"><span class="conf-source-dot" style="background:var(--amber)"></span>IT 日志</span><span>0.88 × 25%</span></div>
          </div>
        </div>
      </div>

      <div class="evi-section">
        <div class="evi-section-title">
          🔐 Chain of Custody
          <span class="count-chip">49</span>
        </div>
        <div style="font-size:10px;color:var(--t3);line-height:1.6">
          已登记 <strong style="color:var(--t1)">49</strong> 条证据链操作记录（文件哈希+时间戳+操作人+工具）。<br>
          <span style="color:var(--t4)">完整审计日志将在 Stage 6 接入</span>
        </div>
      </div>
    </aside>

  </div>
</div><!-- /#view-case -->

<!-- ══════════════════════════════════════════════
     AGENT DETAIL MODAL  (内容 Stage 4 实现)
════════════════════════════════════════════════ -->
<div id="agent-modal" onclick="handleModalOverlay(event)">
  <div id="agent-modal-box">
    <div class="modal-head">
      <div class="modal-head-icon icon-orch" id="modal-icon">🧠</div>
      <div class="modal-head-info">
        <div class="modal-head-title" id="modal-title">Agent 详情</div>
        <div class="modal-head-sub" id="modal-sub">
          <span id="modal-layer-tag" class="tag tag-blue"></span>
          <span id="modal-hitl-badge" class="hitl-badge hitl-3"></span>
        </div>
      </div>
      <button class="modal-close" onclick="closeAgentModal()">✕</button>
    </div>
    <div class="modal-body" id="agent-modal-body">
      <p style="color:var(--t3);font-size:13px;text-align:center;padding:40px 0">
        Agent 详细设计内容 — Stage 4 实现
      </p>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════
     AGENT REACT SIDE PANEL  (Stage 6+ 实现)
════════════════════════════════════════════════ -->
<div id="agent-side-panel">
  <div class="side-head">
    <span class="side-head-title" id="side-panel-agent-name">Agent ReAct 推理日志</span>
    <button class="side-head-close" onclick="closeSidePanel()">✕</button>
  </div>
  <div class="side-body" id="side-panel-body">
    <p style="color:var(--t3);font-size:12px;padding:20px 0;text-align:center">
      ReAct 日志将在 Stage 6 实现
    </p>
  </div>
</div>

<div id="toast-container"></div>
<div id="tooltip"></div>

<script>
/* ══════════════════════════════════════════════
   THEME
══════════════════════════════════════════════ */
function toggleTheme(){
  const html=document.documentElement;
  const isDark=html.dataset.theme==='dark';
  html.dataset.theme=isDark?'light':'dark';
  localStorage.setItem('mt-theme',html.dataset.theme);
  document.getElementById('theme-icon').textContent=isDark?'🌙':'☀️';
  document.getElementById('theme-text').textContent=isDark?'深色模式':'浅色模式';
  // Redraw org chart so SVG colors stay in sync
  redrawOrgChart();
}

(function initTheme(){
  const saved=localStorage.getItem('mt-theme');
  if(saved==='dark'){
    document.documentElement.dataset.theme='dark';
    document.getElementById('theme-icon').textContent='☀️';
    document.getElementById('theme-text').textContent='浅色模式';
  }
})();

/* ══════════════════════════════════════════════
   VIEW SWITCHING
══════════════════════════════════════════════ */
function showView(name){
  // Deactivate all views
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  // Deactivate all nav links
  document.querySelectorAll('.nav-link').forEach(l=>l.classList.remove('active'));

  const view=document.getElementById('view-'+name);
  const link=document.getElementById('nav-'+name);
  if(view) view.classList.add('active');
  if(link) link.classList.add('active');

  // Close any open overlays
  closeAgentModal();
  closeSidePanel();

  // Scroll to top
  window.scrollTo({top:0,behavior:'instant'});

  // Case view init — always reset to Step 1 on entry
  if(name==='case') {
    currentStep = 1;
    setTimeout(caseInit, 50);
    setTimeout(animateConfGauge, 400);
  }
}

/* ══════════════════════════════════════════════
   AGENT MODAL
══════════════════════════════════════════════ */
// ── Agent metadata (V3 canonical IDs, Stage 4 will inject full content) ──
const AGENT_META={
  orchestrator:{
    icon:'⚡',iconClass:'',iconBg:'var(--gold-l)',title:'总指挥',
    sub:'Orchestrator Agent · Agent 0',
    layerTag:'Layer 1 · 指挥层',layerClass:'tag-gold',
    hitlText:'⏸ Tier 1 — 必须审批',hitlClass:'hitl-1',
    steps:'Step 1 · 8 · 12',engine:'状态机 + 条件路由'
  },
  doc_intel:{
    icon:'📄',iconClass:'icon-analysis',iconBg:'',title:'文档情报官',
    sub:'Document Intelligence Agent · Agent 1',
    layerTag:'Layer 2 · 算法分析层',layerClass:'tag-blue',
    hitlText:'⚙ Tier 3 — 全自动',hitlClass:'hitl-3',
    steps:'Steps 2 · 3 · 4',engine:'算法引擎 ⚙'
  },
  entity:{
    icon:'🕸',iconClass:'icon-analysis',iconBg:'',title:'实体图谱官',
    sub:'Entity Resolution & Graph Agent · Agent 2',
    layerTag:'Layer 2 · 算法分析层',layerClass:'tag-blue',
    hitlText:'⚙ Tier 3 — 全自动',hitlClass:'hitl-3',
    steps:'Steps 5 · 6',engine:'算法引擎 ⚙'
  },
  statistical:{
    icon:'📊',iconClass:'icon-analysis',iconBg:'',title:'统计核查官',
    sub:'Statistical Analysis Agent · Agent 3',
    layerTag:'Layer 2 · 算法分析层',layerClass:'tag-blue',
    hitlText:'⚙ Tier 3 — 全自动',hitlClass:'hitl-3',
    steps:'Step 7a · 统计线',engine:'算法引擎 ⚙'
  },
  behavioral:{
    icon:'👤',iconClass:'icon-analysis',iconBg:'',title:'行为画像官',
    sub:'Behavioral Profiling Agent · Agent 4',
    layerTag:'Layer 2 · 算法分析层',layerClass:'tag-blue',
    hitlText:'⚙ Tier 3 — 全自动',hitlClass:'hitl-3',
    steps:'Step 7b · 行为线',engine:'算法引擎 ⚙'
  },
  hypothesis:{
    icon:'🔬',iconClass:'icon-synthesis',iconBg:'',title:'假设验证官',
    sub:'Hypothesis Testing Agent · Agent 5',
    layerTag:'Layer 3 · AI 推理层',layerClass:'tag-purple',
    hitlText:'👁 Tier 2 — 事后审阅',hitlClass:'hitl-2',
    steps:'Steps 8 · 9',engine:'AI 辅助 ✨'
  },
  reporter:{
    icon:'📋',iconClass:'icon-synthesis',iconBg:'',title:'合规报告官',
    sub:'Report Generation Agent · Agent 6',
    layerTag:'Layer 3 · AI 推理层',layerClass:'tag-purple',
    hitlText:'⏸ Tier 1 — 必须审批',hitlClass:'hitl-1',
    steps:'Steps 10 · 11',engine:'AI 辅助 ✨'
  },
};

function openAgentModal(agentId){
  const meta=AGENT_META[agentId]||{
    icon:'🤖',iconClass:'icon-analysis',iconBg:'',title:'Agent',
    sub:'',layerTag:'',layerClass:'tag-blue',
    hitlText:'',hitlClass:'hitl-3',steps:'',engine:''
  };

  // Populate header icon
  const iconEl=document.getElementById('modal-icon');
  iconEl.textContent=meta.icon;
  if(meta.iconBg){
    iconEl.className='modal-head-icon';
    iconEl.style.background=meta.iconBg;
  } else {
    iconEl.className='modal-head-icon '+(meta.iconClass||'icon-analysis');
    iconEl.style.background='';
  }

  document.getElementById('modal-title').textContent=meta.title;

  // Sub line: layer tag + HITL badge + steps (always regenerated via innerHTML)
  document.getElementById('modal-sub').innerHTML=`
    <span class="tag ${meta.layerClass}" style="font-size:9px">${meta.layerTag}</span>
    <span class="hitl-badge ${meta.hitlClass}" style="font-size:9px">${meta.hitlText}</span>
    ${meta.steps?`<span style="color:var(--t3);font-size:10px">· ${meta.steps}</span>`:''}
  `;

  // Stage 4: inject full 2-column modal content
  document.getElementById('agent-modal-body').innerHTML = buildModalBody(agentId);
  // Scroll modal body to top
  document.getElementById('agent-modal-body').scrollTop = 0;

  document.getElementById('agent-modal').classList.add('open');
  document.body.style.overflow='hidden';
}

/* ══════════════════════════════════════════════
   ORG CHART  — SVG connection lines
══════════════════════════════════════════════ */
function drawOrgChart(){
  const svg=document.getElementById('org-svg');
  const canvas=document.getElementById('org-canvas');
  if(!svg||!canvas) return;

  // Clear existing paths (keep defs)
  while(svg.lastChild) svg.removeChild(svg.lastChild);

  // Arrowhead markers
  svg.innerHTML=`
    <defs>
      <marker id="arr-blue" viewBox="0 0 10 10" refX="8" refY="5"
        markerWidth="5" markerHeight="5" orient="auto-start-reverse">
        <path d="M0,1 L9,5 L0,9 Z" fill="rgba(59,130,246,0.65)"/>
      </marker>
      <marker id="arr-gray" viewBox="0 0 10 10" refX="8" refY="5"
        markerWidth="5" markerHeight="5" orient="auto-start-reverse">
        <path d="M0,1 L9,5 L0,9 Z" fill="rgba(148,163,184,0.7)"/>
      </marker>
    </defs>
  `;

  const cRect=canvas.getBoundingClientRect();

  // Get node center/top/bottom relative to canvas
  function pt(nodeId){
    const el=document.getElementById(nodeId);
    if(!el) return null;
    const r=el.getBoundingClientRect();
    return {
      cx: r.left - cRect.left + r.width/2,
      top: r.top - cRect.top,
      bottom: r.bottom - cRect.top,
    };
  }

  function addPath(x1,y1,x2,y2,color,dashed,arrowId){
    const mid=(y1+y2)/2;
    const p=document.createElementNS('http://www.w3.org/2000/svg','path');
    p.setAttribute('d',`M ${x1.toFixed(1)} ${y1.toFixed(1)} C ${x1.toFixed(1)} ${mid.toFixed(1)}, ${x2.toFixed(1)} ${mid.toFixed(1)}, ${x2.toFixed(1)} ${(y2-2).toFixed(1)}`);
    p.setAttribute('fill','none');
    p.setAttribute('stroke',color);
    p.setAttribute('stroke-width','1.5');
    if(dashed) p.setAttribute('stroke-dasharray','5,3');
    p.setAttribute('marker-end',`url(#${arrowId})`);
    svg.appendChild(p);
  }

  const n0=pt('on-0');
  const n1=pt('on-1');
  const n2=pt('on-2');
  const n3=pt('on-3');
  const n4=pt('on-4');
  const n5=pt('on-5');
  const n6=pt('on-6');
  if(!n0||!n1||!n5) return;

  // Orchestrator → 4 analysis agents (gray dashed — dispatch/oversight)
  [n1,n2,n3,n4].forEach(n=>{
    if(n) addPath(n0.cx,n0.bottom, n.cx,n.top, 'rgba(148,163,184,0.55)',true,'arr-gray');
  });

  // 4 analysis agents → Hypothesis Testing (blue solid — data output)
  [n1,n2,n3,n4].forEach(n=>{
    if(n&&n5) addPath(n.cx,n.bottom, n5.cx,n5.top, 'rgba(59,130,246,0.50)',false,'arr-blue');
  });

  // Hypothesis Testing → Report Generation (blue — handoff)
  if(n5&&n6) addPath(n5.cx,n5.bottom, n6.cx,n6.top, 'rgba(59,130,246,0.65)',false,'arr-blue');
}

// Draw on load + resize + theme toggle
function redrawOrgChart(){
  requestAnimationFrame(()=>{ setTimeout(drawOrgChart,60); });
}
window.addEventListener('load', redrawOrgChart);
window.addEventListener('resize', drawOrgChart);
// Redraw when theme changes (colors shift)
const _origToggle=toggleTheme;
// toggleTheme is already defined above, patch it post-definition via wrapper below

function closeAgentModal(){
  document.getElementById('agent-modal').classList.remove('open');
  document.body.style.overflow='';
}

function handleModalOverlay(e){
  if(e.target===document.getElementById('agent-modal')) closeAgentModal();
}

/* ══════════════════════════════════════════════
   SIDE PANEL
══════════════════════════════════════════════ */
function openSidePanel(agentName, content){
  document.getElementById('side-panel-agent-name').textContent=agentName||'Agent ReAct 日志';
  if(content) document.getElementById('side-panel-body').innerHTML=content;
  document.getElementById('agent-side-panel').classList.add('open');
}

function closeSidePanel(){
  document.getElementById('agent-side-panel').classList.remove('open');
}

/* ══════════════════════════════════════════════
   TOAST
══════════════════════════════════════════════ */
function showToast(icon,text,dur=3000){
  const c=document.getElementById('toast-container');
  const t=document.createElement('div');
  t.className='toast';
  t.innerHTML=`<span class="toast-icon">${icon}</span>
    <span class="toast-text">${text}</span>
    <span class="toast-close" onclick="this.parentElement.remove()">×</span>`;
  c.appendChild(t);
  setTimeout(()=>{
    t.classList.add('removing');
    setTimeout(()=>t.remove(),250);
  },dur);
}

/* ══════════════════════════════════════════════
   KEYBOARD SHORTCUTS
══════════════════════════════════════════════ */
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){
    closeAgentModal();
    closeSidePanel();
  }
  // H = home, C = case
  if(!e.metaKey&&!e.ctrlKey&&!e.altKey){
    const tag=document.activeElement?.tagName;
    if(tag==='INPUT'||tag==='TEXTAREA') return;
    if(e.key==='h'||e.key==='H') showView('home');
    if(e.key==='c'||e.key==='C') showView('case');
  }
});

/* ══════════════════════════════════════════════
   STAGE 4 — AGENT CONTENT DATA
══════════════════════════════════════════════ */
const AGENT_CONTENT={

