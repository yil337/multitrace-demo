      {name:'pdf_export()',desc:'带元数据签名的最终 PDF 报告导出'},
    ],
    inputSchema:`{
  "hypothesis_package": {
    "final_hypothesis": object,
    "confidence":       0.92,
    "evidence_chain":   array   // EV-ID 列表
  },
  "style_guide": "SSFS_No1",
  "subject":     "张建国"
}`,
    outputSchema:`{
  "report": {
    "sections":    array,   // 各章节（含 EV-ID 引用）
    "confidence":  0.92,
    "disclaimer":  string   // SSFS 合规声明
  },
  "interview_questions": {
    "round_1": array, // 背景性问题
    "round_2": array, // 异常核实
    "round_3": array  // 对质问题
  }
}`,
    hitl:{tier:1,title:'⏸ Tier 1 — 必须人工审批',
