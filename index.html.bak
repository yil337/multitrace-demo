/* ─────────────── Step 12 — 移交处置 ─────────────── */
12: () => `
<div class="step-section">
  <div class="step-section-title">⚖ 四情景处置方案矩阵（《中央企业合规管理办法》国资委令第43号(2022)）</div>
  <div class="step-table-wrap">
    <table class="step-table">
      <thead>
        <tr><th>情景</th><th>置信度范围</th><th>建议行动</th><th>本案适用</th></tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>立即移交司法</strong></td>
          <td>&gt;90%，有直接证据</td>
          <td>报警 + 证据移送检察机关</td>
          <td class="td-warn"><span class="twm-chip twm-warn">⚠ 待银行流水确认后升级</span></td>
        </tr>
