/* ─────────────── Step 10 — 访谈准备 ─────────────── */
10: () => `
<div class="step-section">
  <div class="step-section-title">🎙 三轮访谈问题包（合规报告官 GPT-4o 生成）</div>

  <div class="interview-round-head">
    <span class="irh-badge irh-r1">第一轮</span>
    <span style="font-weight:600;color:var(--t1)">背景核实</span>
    <span class="irh-desc">建立基准叙述 — 非对抗性，开放式问题</span>
  </div>
  <div class="interview-q">
    <span class="iq-tech">开放式</span>"请描述您与 ABC 电子科技有限公司的商业合作是如何建立的？第一次联系是通过什么渠道？"
  </div>
  <div class="interview-q">
    <span class="iq-tech">开放式</span>"在 2024 年三份采购合同的决策过程中，您是否与其他供应商进行了比价？如有，比价记录存档在哪里？"
  </div>
  <div class="interview-q">
    <span class="iq-tech">细节追问</span>"您在签署合同前，是否知悉合同单价高于 CECA 市场参考均价 38-40%？"
  </div>

  <div class="interview-round-head">
    <span class="irh-badge irh-r2">第二轮</span>
    <span style="font-weight:600;color:var(--t1)">异常确认</span>
    <span class="irh-desc">针对具体异常事件，要求解释</span>
  </div>
  <div class="interview-q round2">
    <span class="iq-tech t-amber">证据呈现</span>"合同 C-2024-089 于 2024 年 4 月 5 日完成付款 ¥234 万，但截至今日 WMS 系统显示入库数量为零（已过 155 天）。请解释货物现状及延误原因。"
  </div>
  <div class="interview-q round2">
    <span class="iq-tech t-amber">细节追问</span>"2024 年 5 月 20 日 23:47，您的账号（USR-001）通过境外 VPN 节点登录文件服务器并访问合同相关文档。请说明该操作的业务目的。"
  </div>
  <div class="interview-q round2">
    <span class="iq-tech t-amber">证据呈现</span>"内审通知发出后次日（即 2024 年 X 月 Y 日），系统日志显示您的账号删除了 127 件文件，较日常基线（2.3 件/天）偏离 113σ。请解释该操作。"
  </div>

  <div class="interview-round-head">
    <span class="irh-badge irh-r3">第三轮</span>
    <span style="font-weight:600;color:var(--t1)">对质</span>
    <span class="irh-desc">基于具体证据的直接对质 — 视第一、二轮回应决定是否执行</span>
  </div>
  <div class="interview-q round3">
    <span class="iq-tech t-red">证据对质</span>"邮件 E018（2024 年 X 月 X 日 22:53 发出）原文写道：'按之前说好的渠道安排妥当'。请问这里的'渠道'具体指什么？'说好的安排'是指哪方面内容？"
  </div>
  <div class="interview-q round3">
    <span class="iq-tech t-red">沉默施压</span>"ABC 电子科技法人代表王磊与您在 2024Q1 期间有 23 次深夜通话记录。在公司采购决策期间，您与供应商法人代表之间存在如此高频私人联系，如何解释？"
  </div>

  <div class="interview-note">
    📋 <strong>访谈合规说明</strong>：本访谈问题清单参照正当程序原则（私营企业内部调查适用）设计，不包含诱供性语言，不承诺任何宽宥安排，调查员可依现场情况灵活调整顺序。本调查为企业内部合规调查，不具有司法强制效力，当事人有权选择不回答任何问题。
  </div>
</div>

<div class="mbadge-wrap">
  ${mb('purple','✨ 访谈设计','Step 10','ACFE FEM 2022 访谈技术分类','开放式 / 细节追问 / 证据呈现 / 沉默施压 — 三轮递进')}
  ${mb('green','✓ 正当程序','Step 10','私营企业内部调查规范','无诱供性语言，当事人知情权已声明')}
</div>`,

/* ─────────────── Step 11 — 报告生成 ─────────────── */
11: () => `
