<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MultiTrace — AI 反腐败多源调查平台</title>
<script src="https://cdn.jsdelivr.net/npm/vis-network@9.1.9/standalone/umd/vis-network.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

/* ══════════════════════════════════════════════
   DESIGN TOKENS  (V2 core preserved + V3 extensions)
══════════════════════════════════════════════ */
:root{
  /* ── Core Surfaces ── */
  --bg:#ffffff;
  --bg2:#f8fafc;
  --bg3:#f1f5f9;
  --bg4:#e9eef5;
  --border:#e2e8f0;
  --border2:#cbd5e1;

  /* ── Typography ── */
  --t1:#0f172a;
  --t2:#475569;
  --t3:#94a3b8;
  --t4:#cbd5e1;

  /* ── Brand Palette ── */
  --blue:#3b82f6;--blue-l:#eff6ff;--blue-m:#dbeafe;--blue-d:#1d4ed8;
  --red:#ef4444;--red-l:#fef2f2;--red-m:#fee2e2;
  --amber:#f59e0b;--amber-l:#fffbeb;--amber-m:#fef3c7;
  --green:#10b981;--green-l:#ecfdf5;--green-m:#d1fae5;
  --purple:#8b5cf6;--purple-l:#f5f3ff;--purple-m:#ede9fe;

  /* ── V3 New: Gold ── */
  --gold:#d4a017;--gold-l:#fffbea;--gold-m:#fef3c7;

  /* ── Shadows ── */
  --shadow-xs:0 1px 2px rgba(0,0,0,.05);
  --shadow-sm:0 1px 3px rgba(0,0,0,.07),0 1px 2px rgba(0,0,0,.04);
  --shadow:0 4px 6px rgba(0,0,0,.05),0 2px 4px rgba(0,0,0,.04);
  --shadow-md:0 10px 15px rgba(0,0,0,.07),0 4px 6px rgba(0,0,0,.04);
  --shadow-lg:0 20px 40px rgba(0,0,0,.10),0 8px 16px rgba(0,0,0,.06);

  /* ── Radius ── */
  --r:8px;--r-sm:5px;--r-lg:14px;

  /* ── Layout ── */
  --nav-h:60px;

  /* ── V3 New: Agent Layer Colors ── */
  --layer-orch:#3b82f6;       /* Orchestrator  */
  --layer-analysis:#f59e0b;   /* Analysis agents */
  --layer-synthesis:#8b5cf6;  /* Synthesis agents */
  --layer-output:#10b981;     /* Output agent */

  /* ── V3 New: Engine Tag Colors ── */
  --eng-langgraph:#6366f1;
  --eng-openai:#10b981;
  --eng-mcp:#f59e0b;
  --eng-spacy:#ef4444;
  --eng-vis:#3b82f6;

  /* ── V3 New: HITL Level Colors ── */
  --hitl-1:#ef4444;   /* Tier 1 — must approve */
  --hitl-2:#f59e0b;   /* Tier 2 — review after */
  --hitl-3:#10b981;   /* Tier 3 — fully auto */
}

/* ── DARK THEME ── */
html[data-theme="dark"]{
  --bg:#0f1117;--bg2:#161b27;--bg3:#1e2535;--bg4:#252d3d;
  --border:#2a3244;--border2:#354257;
  --t1:#f1f5f9;--t2:#94a3b8;--t3:#64748b;--t4:#475569;
  --blue-l:#172033;--blue-m:#1e3a5f;
  --red-l:#1f1315;--red-m:#3b1a1a;
  --amber-l:#1f1a0f;--amber-m:#3b2a0f;
  --green-l:#0f1f18;--green-m:#1a3327;
  --purple-l:#1a1527;--purple-m:#2d1f4a;
  --gold-l:#1f1a0d;--gold-m:#3b2e0a;
  --shadow-xs:0 1px 2px rgba(0,0,0,.3);
  --shadow-sm:0 1px 3px rgba(0,0,0,.4),0 1px 2px rgba(0,0,0,.3);
  --shadow-md:0 10px 15px rgba(0,0,0,.4),0 4px 6px rgba(0,0,0,.3);
  --shadow-lg:0 20px 40px rgba(0,0,0,.5),0 8px 16px rgba(0,0,0,.35);
}

/* ══════════════════════════════════════════════
   BASE
══════════════════════════════════════════════ */
html{scroll-behavior:smooth}
body{
  background:var(--bg2);
  color:var(--t1);
  font-family:-apple-system,BlinkMacSystemFont,'PingFang SC','Helvetica Neue',sans-serif;
  font-size:13px;
  line-height:1.5;
  -webkit-font-smoothing:antialiased;
}

/* ══════════════════════════════════════════════
   TOP NAVIGATION
══════════════════════════════════════════════ */
#nav{
  position:fixed;top:0;left:0;right:0;
  height:var(--nav-h);
  background:var(--bg);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;
  padding:0 32px;gap:0;
  z-index:100;
  box-shadow:var(--shadow-xs);
}

.nav-logo{
  display:flex;align-items:center;gap:10px;
  text-decoration:none;color:inherit;
  margin-right:36px;cursor:pointer;
  flex-shrink:0;
}
.nav-logo-box{
  width:32px;height:32px;border-radius:8px;
  background:linear-gradient(135deg,#3b82f6,#6366f1);
  display:flex;align-items:center;justify-content:center;
  color:#fff;font-size:13px;font-weight:800;
  flex-shrink:0;
  box-shadow:0 2px 8px rgba(99,102,241,.35);
}
.nav-logo-name{
  font-size:15px;font-weight:800;letter-spacing:-.3px;color:var(--t1);
}
.nav-logo-sub{
  font-size:9px;font-weight:500;color:var(--t3);
  letter-spacing:.5px;text-transform:uppercase;margin-top:1px;
}

.nav-links{display:flex;align-items:center;gap:2px}
.nav-link{
  padding:7px 14px;border-radius:6px;
  font-size:13px;font-weight:500;color:var(--t2);
  cursor:pointer;border:none;background:none;
  transition:background .12s,color .12s;
  position:relative;white-space:nowrap;
}
.nav-link:hover{background:var(--bg3);color:var(--t1)}
.nav-link.active{color:var(--blue);background:var(--blue-l)}
.nav-link.active::after{
  content:'';position:absolute;
  bottom:-1px;left:0;right:0;height:2px;
  background:var(--blue);
  border-radius:2px 2px 0 0;
}

.nav-spacer{flex:1}

.nav-demo-badge{
  display:flex;align-items:center;gap:5px;
  background:var(--amber-l);border:1px solid var(--amber-m);
  border-radius:20px;padding:3px 10px;
  font-size:10px;font-weight:600;color:var(--amber);
  margin-right:14px;white-space:nowrap;
}
.nav-demo-dot{
  width:5px;height:5px;border-radius:50%;
  background:var(--amber);animation:pulse 2s infinite;
  flex-shrink:0;
}

.nav-theme-btn{
  display:flex;align-items:center;gap:6px;
  background:var(--bg3);border:1px solid var(--border);
  border-radius:6px;padding:6px 11px;cursor:pointer;
  color:var(--t2);font-size:11px;font-weight:500;
  transition:all .15s;white-space:nowrap;
}
.nav-theme-btn:hover{color:var(--t1);border-color:var(--border2);background:var(--bg4)}

/* ══════════════════════════════════════════════
   VIEWS
══════════════════════════════════════════════ */
.view{
  display:none;
  margin-top:var(--nav-h);
  min-height:calc(100vh - var(--nav-h));
}
.view.active{display:block}

/* ══════════════════════════════════════════════
   SHARED COMPONENTS
══════════════════════════════════════════════ */

/* ── Buttons ── */
.btn{
  border:none;border-radius:var(--r);padding:8px 16px;
  font-size:13px;font-weight:500;cursor:pointer;
  transition:opacity .15s,transform .1s,box-shadow .15s;
  white-space:nowrap;display:inline-flex;align-items:center;gap:6px;
}
.btn:hover{opacity:.88}
.btn:active{transform:scale(.97)}
.btn:disabled{opacity:.4;cursor:not-allowed}
.btn-primary{background:var(--blue);color:#fff;box-shadow:0 2px 8px rgba(59,130,246,.3)}
.btn-primary:hover{box-shadow:0 4px 12px rgba(59,130,246,.4)}
.btn-danger{background:var(--red);color:#fff}
.btn-success{background:var(--green);color:#fff}
.btn-ghost{background:var(--bg3);color:var(--t2);border:1px solid var(--border)}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--t2)}
.btn-lg{padding:12px 24px;font-size:14px;font-weight:600;border-radius:10px}

/* ── Tags ── */
.tag{
  display:inline-flex;align-items:center;
  font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px;
  white-space:nowrap;letter-spacing:.2px;
}
.tag-blue{background:var(--blue-m);color:var(--blue)}
.tag-red{background:var(--red-m);color:var(--red)}
.tag-amber{background:var(--amber-m);color:var(--amber)}
.tag-green{background:var(--green-m);color:var(--green)}
.tag-purple{background:var(--purple-m);color:var(--purple)}
.tag-gold{background:var(--gold-m);color:var(--gold)}

/* ── Engine Tags ── */
.eng-tag{
  display:inline-flex;align-items:center;gap:4px;
  font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;
  font-family:ui-monospace,'SF Mono',monospace;letter-spacing:.3px;
}
.eng-langgraph{background:rgba(99,102,241,.12);color:var(--eng-langgraph);border:1px solid rgba(99,102,241,.25)}
.eng-openai{background:rgba(16,185,129,.12);color:var(--eng-openai);border:1px solid rgba(16,185,129,.25)}
.eng-mcp{background:rgba(245,158,11,.12);color:var(--eng-mcp);border:1px solid rgba(245,158,11,.25)}
.eng-spacy{background:rgba(239,68,68,.12);color:var(--eng-spacy);border:1px solid rgba(239,68,68,.25)}
.eng-vis{background:rgba(59,130,246,.12);color:var(--eng-vis);border:1px solid rgba(59,130,246,.25)}

/* ── HITL Level Badges ── */
.hitl-badge{
  display:inline-flex;align-items:center;gap:4px;
  font-size:9px;font-weight:700;padding:2px 8px;border-radius:4px;white-space:nowrap;
}
.hitl-badge::before{
  content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0;
}
.hitl-1{background:var(--red-m);color:var(--red);border:1px solid #fca5a5}
.hitl-1::before{background:var(--red)}
.hitl-2{background:var(--amber-m);color:var(--amber);border:1px solid #fcd34d}
.hitl-2::before{background:var(--amber)}
.hitl-3{background:var(--green-m);color:var(--green);border:1px solid #6ee7b7}
.hitl-3::before{background:var(--green)}

/* ── Panel ── */
.panel{
  background:var(--bg);border:1px solid var(--border);
  border-radius:var(--r);box-shadow:var(--shadow-sm);
  display:flex;flex-direction:column;overflow:hidden;
}
.panel-head{
  padding:10px 16px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:8px;flex-shrink:0;
}
.panel-title{font-size:13px;font-weight:600;color:var(--t1);flex:1}
.panel-body{flex:1;overflow:auto}

/* ── Methodology Badge ── */
.meth-badge{
  display:inline-flex;align-items:center;gap:5px;
  font-size:10px;font-weight:500;color:var(--t2);
  background:var(--bg2);border:1px solid var(--border);
  border-radius:20px;padding:3px 10px;
  white-space:nowrap;cursor:default;
}
.meth-type{color:var(--blue);font-weight:700}
.meth-sep{color:var(--t4);margin:0 1px}
.meth-step{color:var(--purple);font-weight:600}
.meth-val{color:var(--red);font-weight:700}

/* ── Table ── */
table{width:100%;border-collapse:collapse}
th{
  padding:7px 10px;text-align:left;
  font-size:10px;font-weight:600;color:var(--t3);
  text-transform:uppercase;letter-spacing:.4px;
  background:var(--bg2);border-bottom:1px solid var(--border);
  position:sticky;top:0;z-index:1;
}
td{
  padding:7px 10px;border-bottom:1px solid var(--bg3);
  font-size:12px;cursor:pointer;
  transition:background .1s;vertical-align:middle;
}
tr:hover td{background:var(--bg2)}
tr.sel td{background:var(--blue-l)}
tr.sel td:first-child{box-shadow:inset 3px 0 0 var(--blue)}

/* ── Risk Badges (for contract table) ── */
.risk-badge{
  display:inline-flex;align-items:center;gap:3px;
  padding:2px 7px;border-radius:4px;font-size:10px;font-weight:500;
}
.risk-h{background:var(--red-m);color:var(--red);border:1px solid #fca5a5}
.risk-l{background:var(--green-m);color:var(--green);border:1px solid #6ee7b7}
.dev-h{color:var(--red);font-weight:700}
.dev-m{color:var(--amber);font-weight:600}
.dev-l{color:var(--green)}

/* ── Tooltip ── */
#tooltip{
  position:fixed;pointer-events:none;z-index:999;display:none;
  background:var(--bg);border:1px solid var(--border);
  border-radius:var(--r);box-shadow:var(--shadow-md);
  padding:10px 13px;max-width:280px;font-size:12px;
}
.tt-time{color:var(--t3);margin-bottom:3px;font-size:11px}
.tt-actor{font-weight:600;color:var(--t1);margin-bottom:3px}
.tt-action{color:var(--t2);margin-bottom:4px}
.tt-reason{
  color:var(--red);font-size:11px;line-height:1.4;
  background:var(--red-l);border-radius:4px;padding:4px 7px;margin-top:4px;
}

/* ── Toast ── */
#toast-container{
  position:fixed;bottom:20px;right:20px;
  display:flex;flex-direction:column;gap:8px;z-index:2000;
}
.toast{
  background:var(--bg);border:1px solid var(--border);
  border-radius:var(--r);box-shadow:var(--shadow-md);
  padding:10px 14px;display:flex;align-items:center;gap:8px;
  font-size:12px;min-width:220px;
  animation:toastIn .25s ease;
}
.toast.removing{animation:toastOut .25s ease forwards}
.toast-icon{font-size:14px;flex-shrink:0}
.toast-text{flex:1;color:var(--t1)}
.toast-close{color:var(--t3);cursor:pointer;font-size:16px;line-height:1}
.toast-close:hover{color:var(--t1)}

/* ── Loading Skeleton ── */
.skeleton{
  background:linear-gradient(90deg,var(--bg3) 25%,var(--bg4) 50%,var(--bg3) 75%);
  background-size:200% 100%;
  animation:shimmer 1.5s infinite;
  border-radius:4px;
}

/* ══════════════════════════════════════════════
   VIEW HOME
══════════════════════════════════════════════ */

/* Hero Section */
.home-hero{
  text-align:center;
  padding:80px 24px 56px;
  max-width:820px;
  margin:0 auto;
}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:7px;
  background:var(--blue-l);border:1px solid var(--blue-m);
  border-radius:20px;padding:4px 14px;
  font-size:11px;font-weight:600;color:var(--blue-d);
  margin-bottom:22px;
}
html[data-theme="dark"] .hero-eyebrow{color:#93c5fd}
.hero-title{
  font-size:44px;font-weight:800;letter-spacing:-.8px;
  color:var(--t1);line-height:1.15;margin-bottom:18px;
}
.hero-title-grad{
  background:linear-gradient(135deg,#3b82f6 0%,#6366f1 50%,#8b5cf6 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}
.hero-sub{
  font-size:15px;color:var(--t2);line-height:1.75;
  max-width:620px;margin:0 auto 32px;
}
.hero-actions{
  display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;
}
.hero-stats{
  display:flex;align-items:center;justify-content:center;gap:28px;
  margin-top:40px;padding-top:32px;
  border-top:1px solid var(--border);flex-wrap:wrap;
}
.hero-stat{text-align:center}
.hero-stat-val{
  font-size:26px;font-weight:800;letter-spacing:-.5px;color:var(--t1);line-height:1;
}
.hero-stat-label{font-size:11px;color:var(--t3);margin-top:4px;font-weight:500}

/* ── Efficiency Comparison Section ── */
.eff-section{padding:0 32px 56px;max-width:1100px;margin:0 auto}
.eff-section-title{font-size:13px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--t3);text-align:center;margin-bottom:24px}
.eff-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
.eff-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r-lg);padding:20px 22px}
.eff-card-label{font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--t4);margin-bottom:10px}
.eff-card-val{font-size:24px;font-weight:800;line-height:1.1;margin-bottom:4px}
.eff-card-sub{font-size:11px;color:var(--t3);line-height:1.5}
.eff-card.eff-before .eff-card-val{color:var(--red)}
.eff-card.eff-after  .eff-card-val{color:var(--green)}
.eff-card.eff-source .eff-card-val{color:var(--blue);font-size:14px;font-weight:600;line-height:1.5}
.eff-divider{display:flex;align-items:center;justify-content:center;font-size:20px;color:var(--t4)}
@media(max-width:640px){.eff-grid{grid-template-columns:1fr}}

/* ── Deploy Architecture Section ── */
.deploy-section{padding:0 32px 64px;max-width:1100px;margin:0 auto}
.deploy-section-title{font-size:13px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--t3);text-align:center;margin-bottom:24px}
.deploy-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.deploy-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px 18px}
.deploy-card-head{display:flex;align-items:center;gap:7px;margin-bottom:12px}
.deploy-card-icon{font-size:16px}
.deploy-card-title{font-size:12px;font-weight:700;color:var(--t1)}
.deploy-card-layer{font-size:9px;font-weight:600;letter-spacing:.4px;text-transform:uppercase;color:var(--t4);display:block;margin-top:1px}
.deploy-item{font-size:10px;color:var(--t2);padding:4px 0;border-bottom:1px solid var(--border);line-height:1.45}
.deploy-item:last-child{border-bottom:none}
.deploy-item code{font-size:9px;background:var(--bg3);padding:1px 4px;border-radius:3px;color:var(--blue)}
.deploy-item .di-warn{color:var(--amber);font-size:9px}
@media(max-width:900px){.deploy-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.deploy-grid{grid-template-columns:1fr}}

/* ── Use Case Strip ── */
.usecase-strip{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin:0 0 28px}
.usecase-tag{font-size:11px;font-weight:600;padding:4px 13px;border-radius:20px;background:var(--bg2);border:1px solid var(--border);color:var(--t3);letter-spacing:.3px}

/* ── Trust Pillars ── */
.trust-section{padding:0 32px 48px;max-width:1100px;margin:0 auto}
.trust-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.trust-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r-lg);padding:22px 24px}
.trust-card-icon{font-size:20px;margin-bottom:8px}
.trust-card-title{font-size:13px;font-weight:700;color:var(--t1);margin-bottom:8px}
.trust-tier-row{display:flex;align-items:flex-start;gap:8px;margin-bottom:7px;font-size:10.5px;color:var(--t2);line-height:1.4}
.trust-tier-badge{font-size:9px;font-weight:700;padding:2px 7px;border-radius:10px;white-space:nowrap;margin-top:1px;flex-shrink:0}
.trust-formula{font-family:ui-monospace,monospace;font-size:10px;color:var(--t3);line-height:1.9;background:var(--bg3);padding:10px 12px;border-radius:6px;margin-top:8px;white-space:pre}
.trust-compliance-row{display:flex;align-items:flex-start;gap:10px;margin-bottom:10px;font-size:11px;color:var(--t2);line-height:1.4}
@media(max-width:900px){.trust-grid{grid-template-columns:1fr}}

/* ── HITL Overview Card ── */
.hitl-overview-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r-lg);padding:24px 28px;margin-bottom:28px}
.hitl-overview-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:16px}
.hitl-ov-col{border-radius:10px;padding:16px 18px}
.hitl-ov-tier{font-size:9px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;margin-bottom:5px}
.hitl-ov-title{font-size:13px;font-weight:700;margin-bottom:10px;color:var(--t1)}
.hitl-ov-steps{font-size:10px;color:var(--t3);line-height:1.65}
.hitl-ov-rule{font-size:10px;font-weight:600;margin-top:10px;padding:4px 10px;border-radius:5px;display:inline-block}
@media(max-width:900px){.hitl-overview-grid{grid-template-columns:1fr}}

/* ══════════════════════════════════════
   VISUALIZATION — Price Chart / Timeline / Behavior Chart
══════════════════════════════════════ */

/* ── Price Deviation Stacked Bar Chart ── */
.price-bar-chart{margin:14px 0 18px}
.pbc-row{margin-bottom:10px}
.pbc-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:4px}
.pbc-label{font-size:11px;font-weight:600;color:var(--t2)}
.pbc-sigma{font-size:10px;font-weight:800;color:var(--red)}
.pbc-track{height:26px;border-radius:7px;background:var(--bg3);overflow:hidden;position:relative;display:flex}
.pbc-market-fill{height:100%;background:rgba(22,163,74,.45);transition:width 1.1s cubic-bezier(.34,1.56,.64,1);display:flex;align-items:center;padding-left:9px;flex-shrink:0}
.pbc-market-txt{font-size:9.5px;font-weight:600;color:rgba(30,200,110,.9);white-space:nowrap}
.pbc-excess-fill{height:100%;background:rgba(220,38,38,.55);transition:width 1.1s cubic-bezier(.34,1.56,.64,1) .1s;display:flex;align-items:center;justify-content:flex-end;padding-right:8px;flex-shrink:0}
.pbc-excess-txt{font-size:9.5px;font-weight:700;color:#fff;white-space:nowrap}
.pbc-legend{display:flex;gap:14px;font-size:10px;color:var(--t4);margin-top:8px}
.pbc-legend-item{display:flex;align-items:center;gap:5px}
.pbc-legend-dot{width:11px;height:11px;border-radius:3px;display:inline-block;flex-shrink:0}
.pbc-ref-badge{font-size:9px;padding:1px 7px;border-radius:10px;background:rgba(22,163,74,.12);color:var(--green);font-weight:600;margin-left:6px}

/* ── Case Event Timeline ── */
.case-timeline-wrap{padding:4px 0 2px}
.ct-item{display:grid;grid-template-columns:78px 14px 1fr;align-items:flex-start;gap:10px;position:relative}
.ct-item:not(:last-child) .ct-line{position:absolute;left:88px;top:16px;bottom:-8px;width:2px;background:var(--border);z-index:0}
.ct-date{font-size:10px;color:var(--t4);text-align:right;padding-top:2px;font-family:ui-monospace,monospace;line-height:1.4}
.ct-dot{width:14px;height:14px;border-radius:50%;border:2px solid var(--border);background:var(--bg2);flex-shrink:0;margin-top:2px;z-index:1;position:relative}
.ct-dot.ct-red{border-color:var(--red);background:rgba(220,38,38,.25)}
.ct-dot.ct-amber{border-color:var(--amber);background:rgba(245,158,11,.2)}
.ct-dot.ct-green{border-color:var(--green);background:rgba(22,163,74,.2)}
.ct-dot.ct-blue{border-color:var(--blue);background:rgba(37,99,235,.2)}
.ct-body{font-size:11.5px;color:var(--t2);line-height:1.5;padding-bottom:14px}
.ct-body strong{color:var(--t1)}
.ct-tag{font-size:9px;font-weight:700;padding:1px 8px;border-radius:10px;display:inline-block;margin-top:4px}
.ct-tag-red{background:rgba(220,38,38,.15);color:var(--red)}
.ct-tag-amber{background:rgba(245,158,11,.15);color:var(--amber)}
.ct-tag-green{background:rgba(22,163,74,.15);color:var(--green)}
.ct-tag-blue{background:rgba(37,99,235,.12);color:var(--blue)}

/* ── Behavioral Anomaly Bar Chart ── */
.behav-bar-chart{display:flex;flex-direction:column;gap:10px;margin:12px 0 14px}
.bbc-row{display:grid;grid-template-columns:90px 1fr 64px;align-items:center;gap:10px}
.bbc-label{font-size:11px;color:var(--t3);text-align:right;line-height:1.4}
.bbc-track{height:22px;border-radius:6px;background:var(--bg3);overflow:hidden;position:relative;display:flex}
.bbc-baseline{height:100%;background:rgba(22,163,74,.45);flex-shrink:0;transition:width 1s ease .1s;display:flex;align-items:center}
.bbc-baseline-tick{width:2px;height:100%;background:rgba(22,163,74,.9);margin-left:auto}
.bbc-anomaly{height:100%;background:rgba(220,38,38,.55);flex-shrink:0;transition:width 1s ease .25s;display:flex;align-items:center;justify-content:flex-end;padding-right:6px}
.bbc-anomaly-txt{font-size:9px;font-weight:700;color:#fff;white-space:nowrap}
.bbc-zscore{font-size:10px;font-weight:800;color:var(--red);white-space:nowrap}
.bbc-legend{display:flex;gap:14px;font-size:10px;color:var(--t4);margin-top:6px}

/* ── Step 8 handoff bridge ── */
.step8-bridge{background:rgba(99,102,241,.05);border:1px dashed rgba(99,102,241,.35);border-radius:10px;padding:14px 18px;margin-top:20px;display:flex;align-items:flex-start;gap:12px;font-size:12px;color:var(--t2);line-height:1.6}
.step8-bridge-icon{font-size:22px;flex-shrink:0;margin-top:2px}

/* ── Step 9 Hypothesis Selection Interaction ── */
.hitl-confirm-section{background:linear-gradient(135deg,rgba(99,102,241,.04),rgba(22,163,74,.04));border:1.5px solid rgba(99,102,241,.4);border-radius:var(--r-lg);padding:22px 26px;margin-top:18px}
.hitl-confirm-title{font-size:15px;font-weight:700;color:var(--t1);margin:10px 0 4px}
.hitl-confirm-sub{font-size:11px;color:var(--t3);line-height:1.5;margin-bottom:16px}
.hyp-select-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:14px}
.hyp-sel-card{background:var(--bg2);border:2px solid var(--border);border-radius:12px;padding:15px 16px;cursor:pointer;transition:border-color .18s,transform .18s,box-shadow .18s,opacity .18s;user-select:none}
.hyp-sel-card:hover:not(.locked){border-color:var(--purple);transform:translateY(-2px);box-shadow:0 4px 16px rgba(99,102,241,.15)}
.hyp-sel-card.selected{border-color:var(--green);background:rgba(22,163,74,.07);box-shadow:0 0 0 3px rgba(22,163,74,.12)}
.hyp-sel-card.rejected{opacity:.45;filter:grayscale(.4)}
.hyp-sel-card.locked{cursor:default}
.hyp-sel-badge{font-size:10px;font-weight:800;padding:2px 9px;border-radius:10px;display:inline-block;margin-bottom:7px}
.h1-badge{background:rgba(22,163,74,.15);color:var(--green)}
.h2-badge{background:rgba(239,68,68,.1);color:var(--red)}
.h3-badge{background:rgba(156,163,175,.15);color:var(--t3)}
.hyp-sel-title{font-size:13px;font-weight:700;color:var(--t1);margin-bottom:3px}
.hyp-sel-conf{font-size:11px;color:var(--t3);margin-bottom:7px}
.hyp-sel-desc{font-size:11px;color:var(--t2);line-height:1.5;margin-bottom:5px}
.hyp-sel-evidence{font-size:10px;color:var(--t4);line-height:1.4;font-style:italic}
.hyp-confirm-btn-wrap{text-align:center;padding-top:6px}
.hyp-selected-summary{font-size:11.5px;color:var(--t2);margin-bottom:10px;padding:9px 13px;background:var(--bg2);border-radius:8px;border-left:3px solid var(--green);text-align:left;line-height:1.6}
.hyp-confirm-btn{background:var(--green);color:#fff;border:none;border-radius:8px;padding:10px 26px;font-size:13px;font-weight:700;cursor:pointer;transition:filter .15s,transform .15s}
.hyp-confirm-btn:hover{filter:brightness(1.1);transform:translateY(-1px)}
.hyp-confirmed-state{text-align:center;padding:22px 16px;background:rgba(22,163,74,.06);border:1.5px solid rgba(22,163,74,.28);border-radius:12px}
.hcs-icon{font-size:30px;margin-bottom:6px}
.hcs-text{font-size:14px;font-weight:700;color:var(--t1);margin-bottom:3px}
.hcs-note{font-size:11px;color:var(--t3);margin-bottom:12px;line-height:1.5}
@media(max-width:900px){.hyp-select-grid{grid-template-columns:1fr}}

/* Org Chart Section */
.org-chart-section{
  padding:0 32px 64px;
  max-width:1000px;margin:0 auto;
}
.section-header{
  text-align:center;margin-bottom:36px;
}
.section-label{
  font-size:10px;font-weight:700;letter-spacing:.8px;
  text-transform:uppercase;color:var(--t3);margin-bottom:8px;
}
.section-title{
  font-size:24px;font-weight:700;color:var(--t1);letter-spacing:-.3px;
}
.section-sub{font-size:13px;color:var(--t2);margin-top:6px;line-height:1.6}

/* Agent Cards Grid */
.agent-cards-section{
  padding:0 32px 80px;
  max-width:1100px;margin:0 auto;
}
.agent-cards-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:16px;
}

/* Individual Agent Card */
.agent-card{
  background:var(--bg);border:1px solid var(--border);
  border-radius:var(--r-lg);box-shadow:var(--shadow-sm);
  padding:20px;cursor:pointer;
  transition:transform .18s,box-shadow .18s,border-color .18s;
  position:relative;overflow:hidden;
}
.agent-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  border-radius:var(--r-lg) var(--r-lg) 0 0;
}
.agent-card:hover{
  transform:translateY(-3px);
  box-shadow:var(--shadow-md);
}
.agent-card.layer-orch{border-top-color:var(--layer-orch)}
.agent-card.layer-orch::before{background:var(--layer-orch)}
.agent-card.layer-analysis{border-top-color:var(--layer-analysis)}
.agent-card.layer-analysis::before{background:var(--layer-analysis)}
.agent-card.layer-synthesis{border-top-color:var(--layer-synthesis)}
.agent-card.layer-synthesis::before{background:var(--layer-synthesis)}
.agent-card.layer-output{border-top-color:var(--layer-output)}
.agent-card.layer-output::before{background:var(--layer-output)}

.agent-card-head{
  display:flex;align-items:flex-start;gap:12px;margin-bottom:12px;
}
.agent-icon{
  width:40px;height:40px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;flex-shrink:0;
}
.icon-orch{background:var(--blue-l)}
.icon-analysis{background:var(--amber-l)}
.icon-synthesis{background:var(--purple-l)}
.icon-output{background:var(--green-l)}
html[data-theme="dark"] .icon-orch{background:var(--blue-m)}
html[data-theme="dark"] .icon-analysis{background:var(--amber-m)}
html[data-theme="dark"] .icon-synthesis{background:var(--purple-m)}
html[data-theme="dark"] .icon-output{background:var(--green-m)}

.agent-card-meta{flex:1;min-width:0}
.agent-name{
  font-size:14px;font-weight:700;color:var(--t1);
  margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.agent-role{font-size:11px;color:var(--t3);font-weight:500}

.agent-card-desc{
  font-size:12px;color:var(--t2);line-height:1.6;
  margin-bottom:14px;
}
.agent-card-tags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px}
.agent-card-footer{
  display:flex;align-items:center;justify-content:space-between;
  padding-top:10px;border-top:1px solid var(--border);
}
.agent-card-steps{font-size:10px;color:var(--t3);font-weight:500}
.agent-card-cta{
  font-size:11px;color:var(--blue);font-weight:600;
  display:flex;align-items:center;gap:3px;
}

/* CTA Section */
.home-cta{
  text-align:center;
  padding:64px 24px 80px;
  background:linear-gradient(180deg,var(--bg2) 0%,var(--bg3) 100%);
  border-top:1px solid var(--border);
}
.home-cta-title{
  font-size:28px;font-weight:800;color:var(--t1);
  letter-spacing:-.4px;margin-bottom:10px;
}
.home-cta-sub{
  font-size:14px;color:var(--t2);margin-bottom:28px;
}

/* ══════════════════════════════════════════════
   VIEW CASE  (placeholder — built in Stage 5–9)
══════════════════════════════════════════════ */
.case-placeholder{
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  gap:16px;
  min-height:calc(100vh - var(--nav-h));
  color:var(--t3);
}
.case-placeholder-icon{font-size:48px;margin-bottom:8px}

/* ══════════════════════════════════════════════
   AGENT DETAIL MODAL
══════════════════════════════════════════════ */
#agent-modal{
  position:fixed;inset:0;
  background:rgba(0,0,0,.55);
  z-index:500;
  display:none;align-items:center;justify-content:center;
  padding:20px;
  backdrop-filter:blur(4px);
  -webkit-backdrop-filter:blur(4px);
}
#agent-modal.open{display:flex;animation:fadeIn .2s ease}
#agent-modal-box{
  background:var(--bg);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  box-shadow:var(--shadow-lg);
  width:100%;max-width:780px;
  max-height:84vh;
  display:flex;flex-direction:column;
  overflow:hidden;
  animation:fadeUp .25s ease;
}
.modal-head{
  padding:18px 20px 16px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:flex-start;gap:14px;
  flex-shrink:0;
}
.modal-head-icon{
  width:44px;height:44px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:20px;flex-shrink:0;
}
.modal-head-info{flex:1;min-width:0}
.modal-head-title{font-size:17px;font-weight:700;color:var(--t1);margin-bottom:3px}
.modal-head-sub{font-size:11px;color:var(--t3);display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.modal-close{
  width:30px;height:30px;border-radius:50%;
  background:var(--bg3);border:none;cursor:pointer;
  font-size:14px;color:var(--t2);
  display:flex;align-items:center;justify-content:center;
  transition:background .15s;flex-shrink:0;margin-top:2px;
}
.modal-close:hover{background:var(--bg4);color:var(--t1)}
.modal-body{flex:1;overflow-y:auto;padding:20px}

/* ══════════════════════════════════════════════
   AGENT REACT SIDE PANEL  (slide in from right)
══════════════════════════════════════════════ */
#agent-side-panel{
  position:fixed;
  top:var(--nav-h);right:0;bottom:0;
  width:320px;
  background:var(--bg);
  border-left:1px solid var(--border);
  box-shadow:var(--shadow-lg);
  z-index:200;
  display:flex;flex-direction:column;
  overflow:hidden;
  transform:translateX(100%);
  transition:transform .25s cubic-bezier(.4,0,.2,1);
  /* Always in DOM, hidden via transform */
  pointer-events:none;
}
#agent-side-panel.open{
  transform:translateX(0);
  pointer-events:auto;
}
.side-head{
  padding:14px 16px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:10px;
  flex-shrink:0;background:var(--bg2);
}
.side-head-title{font-size:12px;font-weight:600;color:var(--t1);flex:1}
.side-head-close{
  width:24px;height:24px;border-radius:50%;
  background:var(--bg3);border:none;cursor:pointer;
  font-size:12px;color:var(--t2);
  display:flex;align-items:center;justify-content:center;
  transition:background .15s;
}
.side-head-close:hover{background:var(--bg4)}
.side-body{flex:1;overflow-y:auto;padding:12px}

/* ReAct Log entry */
.react-entry{
  margin-bottom:10px;
  border:1px solid var(--border);
  border-radius:var(--r-sm);
  overflow:hidden;
}
.react-entry-header{
  padding:6px 10px;background:var(--bg2);
  font-size:10px;font-weight:600;color:var(--t3);
  display:flex;align-items:center;gap:6px;
}
.react-entry-body{
  padding:8px 10px;font-size:11px;color:var(--t2);line-height:1.55;
}
.react-thought{color:var(--purple)}
.react-action{color:var(--blue)}
.react-obs{color:var(--green)}

/* ══════════════════════════════════════════════
   ANIMATIONS
══════════════════════════════════════════════ */
@keyframes shimmer{to{background-position:-200% 0}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
@keyframes toastIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:none}}
@keyframes toastOut{to{opacity:0;transform:translateX(20px)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideInRight{from{opacity:0;transform:translateX(24px)}to{opacity:1;transform:none}}

/* ══════════════════════════════════════════════
   ORG CHART
══════════════════════════════════════════════ */
.org-canvas{
  position:relative;
  padding:28px 32px 36px;
  background:var(--bg);
  border-radius:var(--r-lg);
  border:1px solid var(--border);
  overflow:hidden;
  min-width:700px;
}
.org-svg-layer{
  position:absolute;inset:0;
  width:100%;height:100%;
  pointer-events:none;
  overflow:visible;
}
.org-row{
  display:flex;align-items:flex-start;
  justify-content:center;gap:14px;
  position:relative;z-index:1;
}
.org-row+.org-row{margin-top:50px}
.org-node{
  background:var(--bg2);
  border:1.5px solid var(--border2);
  border-radius:10px;
  padding:10px 14px 12px;
  min-width:152px;max-width:172px;
  text-align:center;cursor:pointer;
  transition:transform .15s,box-shadow .18s,border-color .15s;
}
.org-node:hover{
  transform:translateY(-2px);
  box-shadow:var(--shadow);
}
.org-node-icon{font-size:20px;line-height:1;margin-bottom:5px}
.org-node-name{
  font-size:13px;font-weight:700;color:var(--t1);
  margin-bottom:2px;white-space:nowrap;
}
.org-node-en{
  font-size:9px;color:var(--t3);
  margin-bottom:6px;white-space:nowrap;
}
.org-node-steps{
  font-size:9px;font-weight:600;
  border-radius:4px;padding:2px 7px;
  display:inline-block;white-space:nowrap;
}

/* Node color variants */
.n-gold{border-color:var(--gold)!important;background:var(--gold-l)}
.n-gold:hover{border-color:#c89010!important}
.n-gold .org-node-steps{background:var(--gold-m);color:var(--gold)}
.n-blue{border-color:var(--blue)!important;background:var(--blue-l)}
.n-blue:hover{border-color:var(--blue-d)!important}
.n-blue .org-node-steps{background:var(--blue-m);color:var(--blue)}
.n-purple{border-color:var(--purple)!important;background:var(--purple-l)}
.n-purple:hover{border-color:#6d28d9!important}
.n-purple .org-node-steps{background:var(--purple-m);color:var(--purple)}

html[data-theme="dark"] .n-gold{background:var(--gold-m)}
html[data-theme="dark"] .n-blue{background:var(--blue-m)}
html[data-theme="dark"] .n-purple{background:var(--purple-m)}

/* Org chart scroll wrapper */
.org-scroll{overflow-x:auto;border-radius:var(--r-lg)}

/* Org legend */
.org-legend{
  display:flex;align-items:center;justify-content:center;gap:20px;
  margin-top:22px;font-size:10px;color:var(--t3);
}
.org-legend-item{display:flex;align-items:center;gap:6px}
.org-legend-line{
  width:22px;height:2px;border-radius:1px;flex-shrink:0;
}

/* ══════════════════════════════════════════════
   AGENT CARD ENHANCEMENTS (Stage 2)
══════════════════════════════════════════════ */
/* Gold orchestrator treatment */
.agent-card.layer-gold{border-top-color:var(--gold)}
.agent-card.layer-gold::before{
  background:linear-gradient(90deg,var(--gold),#f59e0b);
}
.agent-card.layer-gold .agent-icon{
  background:var(--gold-l);
}
html[data-theme="dark"] .agent-card.layer-gold .agent-icon{
  background:var(--gold-m);
}

/* Full-width orchestrator card spans all columns */
.agent-card.card-full{grid-column:1/-1}

/* Agent number badge */
.agent-num{
  font-size:9px;font-weight:700;
  color:var(--t4);background:var(--bg3);
  border-radius:4px;padding:1px 5px;
  margin-left:6px;vertical-align:middle;
}

/* Tagline (replaces old desc for Stage 2+ cards) */
.agent-tagline{
  font-size:12px;font-weight:600;color:var(--t1);
  line-height:1.55;margin-bottom:10px;
  padding-bottom:10px;border-bottom:1px solid var(--border);
}

/* Ability bullets */
.agent-abilities{margin-bottom:12px}
.ability-item{
  font-size:11px;color:var(--t2);padding:2px 0;
  line-height:1.5;display:flex;align-items:flex-start;gap:6px;
}
.ability-dot{
  width:4px;height:4px;border-radius:50%;
  background:var(--blue);flex-shrink:0;margin-top:5px;
}
.agent-card.layer-gold .ability-dot{background:var(--gold)}
.agent-card.layer-synthesis .ability-dot{background:var(--purple)}
.agent-card.layer-output .ability-dot{background:var(--green)}
.ability-cite{
  font-size:9px;color:var(--t4);
  font-family:ui-monospace,monospace;margin-left:2px;
}

/* ══════════════════════════════════════════════
   CTA CASE CARD
══════════════════════════════════════════════ */
.case-card{
  display:inline-flex;align-items:stretch;gap:0;
  background:var(--bg);border:1px solid var(--border);
  border-radius:var(--r-lg);box-shadow:var(--shadow-sm);
  margin-bottom:28px;overflow:hidden;flex-wrap:wrap;
}
.case-card-field{
  padding:14px 20px;text-align:left;border-right:1px solid var(--border);
}
.case-card-field:last-child{border-right:none}
.case-card-label{
  font-size:9px;font-weight:700;color:var(--t3);
  text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;
}
.case-card-val{font-size:13px;font-weight:600;color:var(--t1);white-space:nowrap}

/* ══════════════════════════════════════════════
   VIEW CASE — STAGE 5  (3-column demo case shell)
══════════════════════════════════════════════ */

/* Override default .view margin-top — case view handles it internally */
#view-case{margin-top:var(--nav-h);min-height:calc(100vh - var(--nav-h));display:none}
#view-case.active{display:flex;flex-direction:column}

/* ── Top compliance bar ── */
.case-topbar{
  flex-shrink:0;
  background:var(--bg);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:12px;
  padding:8px 18px;min-height:44px;
  font-size:11px;
}
.case-crumb{
  color:var(--t3);display:flex;align-items:center;gap:6px;
  flex-shrink:0;
}
.case-crumb a{color:var(--blue);cursor:pointer;text-decoration:none}
.case-crumb a:hover{text-decoration:underline}
.case-crumb-sep{color:var(--t4)}

.case-rules{
  display:flex;align-items:center;gap:5px;
  padding-left:10px;margin-left:4px;
  border-left:1px solid var(--border);
}
.rule-pill{
  display:inline-flex;align-items:center;gap:4px;
  padding:3px 9px;border-radius:14px;
  font-size:10px;font-weight:600;
  background:var(--green-l);color:#065f46;
  border:1px solid #6ee7b7;white-space:nowrap;
}
html[data-theme="dark"] .rule-pill{background:var(--green-m);color:#6ee7b7}
.rule-pill::before{content:'✓';font-size:10px;font-weight:800}

.case-meta-spacer{flex:1}

.case-tag{
  display:inline-flex;align-items:center;gap:5px;
  padding:3px 9px;border-radius:4px;
  font-size:10px;font-weight:600;white-space:nowrap;
}
.case-tag-id{
  background:var(--blue-l);color:var(--blue-d);
  font-family:ui-monospace,monospace;
}
html[data-theme="dark"] .case-tag-id{color:#93c5fd}
.case-tag-demo{
  background:var(--amber-l);color:#92400e;
  border:1px solid var(--amber-m);
}
html[data-theme="dark"] .case-tag-demo{color:#fcd34d}
.case-tag-demo::before{
  content:'';width:5px;height:5px;border-radius:50%;
  background:var(--amber);animation:pulse 2s infinite;margin-right:1px;
}
.case-tag-conf{
  background:var(--red-l);color:var(--red);
  border:1px solid #fca5a5;font-weight:700;
}

/* ── 3-column body ── */
.case-body{
  flex:1;
  display:grid;
  grid-template-columns:210px 1fr 320px;
  overflow:hidden;
  min-height:0;
}
.case-body.side-open{grid-template-columns:210px 1fr 320px 320px}

/* ── Left spine (12 steps) ── */
.case-spine{
  background:var(--bg);
  border-right:1px solid var(--border);
  overflow-y:auto;
  padding:16px 0 24px;
  position:relative;
}
.spine-title{
  font-size:10px;font-weight:700;color:var(--t3);
  text-transform:uppercase;letter-spacing:.6px;
  padding:0 16px 10px;
  border-bottom:1px solid var(--border);
  margin-bottom:8px;
}
.spine-list{
  position:relative;padding:0 10px;
}
.spine-list::before{
  /* Vertical connector line */
  content:'';
  position:absolute;
  left:25px;top:14px;bottom:14px;
  width:2px;background:var(--border);
  z-index:0;
}
.spine-step{
  position:relative;
  display:flex;align-items:center;gap:9px;
  padding:7px 10px;border-radius:5px;
  cursor:pointer;z-index:1;
  transition:background .12s;
}
.spine-step:hover{background:var(--bg3)}
.spine-step.active{
  background:var(--blue-l);
}
.spine-step.active::before{
  content:'';position:absolute;
  left:0;top:3px;bottom:3px;width:3px;
  background:var(--blue);border-radius:0 3px 3px 0;
}
.spine-num{
  width:22px;height:22px;border-radius:50%;
  background:var(--bg3);border:2px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:10px;font-weight:700;color:var(--t3);
  flex-shrink:0;z-index:2;
}
.spine-step.completed .spine-num{
  background:var(--green);color:#fff;border-color:var(--green);
}
.spine-step.completed .spine-num::after{content:''}
.spine-step.active .spine-num{
  background:var(--blue);color:#fff;border-color:var(--blue);
  box-shadow:0 0 0 3px var(--blue-l);
}
.spine-step.pending .spine-num{color:var(--t4)}
.spine-label{
  flex:1;min-width:0;
  font-size:11px;font-weight:500;color:var(--t2);
  line-height:1.3;
}
.spine-step.active .spine-label{color:var(--t1);font-weight:700}
.spine-step.completed .spine-label{color:var(--t2)}
.spine-step.pending .spine-label{color:var(--t4)}
.spine-label-sub{
  font-size:9px;color:var(--t4);margin-top:1px;font-weight:500;
}
.spine-hitl-dot{
  width:6px;height:6px;border-radius:50%;flex-shrink:0;
  margin-left:auto;
}
.spine-hitl-1{background:var(--red)}
.spine-hitl-2{background:var(--amber)}
.spine-hitl-3{background:var(--green)}

/* ── Main content area ── */
.case-main{
  overflow-y:auto;
  padding:18px 22px 40px;
  background:var(--bg2);
}

/* ── Spine selected state (click-selected) ── */
.spine-step.spine-selected{
  background:var(--blue-l) !important;
}
.spine-step.spine-selected::before{
  content:'';position:absolute;
  left:0;top:3px;bottom:3px;width:3px;
  background:var(--blue);border-radius:0 3px 3px 0;
}
.spine-num-completed{background:var(--green)!important;color:#fff!important;border-color:var(--green)!important}
.spine-num-active{background:var(--blue)!important;color:#fff!important;border-color:var(--blue)!important;box-shadow:0 0 0 3px var(--blue-l)}
.spine-num-pending{color:var(--t4)!important}

/* Step card header */
.step-head{
  background:var(--bg);border:1px solid var(--border);
  border-radius:var(--r-lg);
  box-shadow:var(--shadow-sm);
  padding:14px 18px;margin-bottom:16px;
  display:flex;align-items:center;gap:14px;
}
.step-head-left{display:flex;align-items:center;gap:12px;flex:1;min-width:0}
.step-head-right{display:flex;align-items:center;gap:8px;flex-shrink:0;flex-wrap:wrap;justify-content:flex-end}
.step-head-num{
  width:44px;height:44px;border-radius:10px;
  background:var(--blue-l);color:var(--blue);
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:800;letter-spacing:-.3px;
  flex-shrink:0;text-align:center;line-height:1.2;
}
.step-head-info{flex:1;min-width:0}
.step-head-name{
  font-size:15px;font-weight:700;color:var(--t1);
  line-height:1.3;margin-bottom:3px;
}
.step-head-sub{
  font-size:11px;color:var(--t3);
}

/* Status pills */
.step-status-pill{
  display:inline-flex;align-items:center;
  padding:3px 9px;border-radius:20px;
  font-size:10px;font-weight:700;
}
.pill-completed{background:var(--green-l);color:var(--green)}
.pill-active{background:var(--blue-l);color:var(--blue);animation:pulse-pill 2s infinite}
.pill-pending{background:var(--bg3);color:var(--t4)}
@keyframes pulse-pill{0%,100%{opacity:1}50%{opacity:.6}}
/* ── Stage 10: Step reveal & agent bar ── */
@keyframes stepReveal{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
@keyframes alProgGrow{from{width:0}to{width:100%}}
/* Agent layer processing bar */
.al-prog-wrap{height:2px;background:var(--border);border-radius:1px;margin:8px 0 0;overflow:hidden}
.al-prog-bar{
  height:100%;
  background:linear-gradient(90deg,var(--blue),var(--green));
  border-radius:1px;width:0;
  animation:alProgGrow .5s cubic-bezier(.4,0,.2,1) forwards;
  transition:opacity .22s .55s ease;
}
.al-prog-bar.done{opacity:0}
/* Table row hover */
.step-table tbody tr{transition:background .1s}
.step-table tbody tr:hover td{background:rgba(37,99,235,.04)!important}
/* Evidence panel item hover */
.evi-item{transition:border-color .15s,background .15s,box-shadow .15s}
.evi-item:hover{border-color:var(--blue);background:var(--blue-l);box-shadow:0 1px 6px rgba(37,99,235,.08)}
/* Step nav button hover */
.step-nav-btn{transition:background .12s,transform .1s,box-shadow .12s}
.step-nav-btn:hover{transform:translateY(-1px);box-shadow:0 4px 12px rgba(0,0,0,.1)}
.step-nav-btn:active{transform:translateY(0)}
/* Hyp bars — JS resets width to 0 then restores for animation */
.hrc-bar-fill{transition:width .65s cubic-bezier(.4,0,.2,1)!important}
/* Confidence bar animated on page load */
.conf-bar-fill{transition:width 1.1s cubic-bezier(.4,0,.2,1)}

/* Agent Layer (new flat structure) */
.agent-layer{
  background:var(--bg);border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:14px 16px;margin-bottom:14px;
  box-shadow:var(--shadow-sm);
}
.agent-layer-label{
  font-size:10px;font-weight:700;letter-spacing:.5px;
  text-transform:uppercase;color:var(--t3);
  margin-bottom:10px;
}
.agent-layer-chips{
  display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px;
}
.agent-layer-hint{
  font-size:10px;color:var(--t4);margin-top:2px;
}

.agent-chip{
  display:inline-flex;align-items:center;gap:7px;
  padding:7px 12px 7px 10px;border-radius:10px;
  background:var(--bg2);border:1px solid var(--border);
  cursor:pointer;
  transition:border-color .15s,transform .1s,box-shadow .15s;
}
.agent-chip:hover{
  border-color:var(--blue);
  box-shadow:0 2px 6px rgba(59,130,246,.18);
  transform:translateY(-1px);
}
.agent-chip.layer-orchestration:hover{border-color:var(--blue)}
.agent-chip.layer-intel:hover{border-color:var(--amber)}
.agent-chip.layer-analysis:hover{border-color:var(--red)}
.agent-chip.layer-synthesis:hover{border-color:var(--purple)}
.agent-chip.layer-output:hover{border-color:var(--green)}
.agent-chip-icon{font-size:18px;line-height:1;flex-shrink:0}
.agent-chip-info{display:flex;flex-direction:column;gap:1px}
.agent-chip-name{font-size:12px;font-weight:700;color:var(--t1);line-height:1}
.agent-chip-num{font-size:9px;color:var(--t4);font-weight:500}
.agent-chip-arrow{font-size:10px;color:var(--t4);margin-left:2px}

/* Step body */
.step-body{
  background:var(--bg);border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:22px 24px;
  min-height:200px;
  box-shadow:var(--shadow-sm);
  animation:stepReveal .24s cubic-bezier(.16,1,.3,1) both;
}
.step-body-content{
  font-size:13px;color:var(--t2);line-height:1.75;
}
.step-body-content strong{color:var(--t1)}
.step-body-content code{
  font-family:ui-monospace,'SF Mono',monospace;
  font-size:11px;background:var(--bg3);
  padding:1px 5px;border-radius:4px;color:var(--blue);
}
.step-body-content em{color:var(--t3);font-style:normal}
.step-body-content br{display:block;content:'';margin-top:4px}
.status-active-label{
  display:inline-block;
  background:var(--blue-l);color:var(--blue);
  font-size:11px;font-weight:700;
  padding:3px 10px;border-radius:20px;
  margin-bottom:10px;
}

/* Step navigation */
.step-nav{
  display:flex;align-items:center;justify-content:space-between;
  margin-top:18px;padding-top:14px;
  border-top:1px dashed var(--border);
}
.step-nav-btn{
  background:var(--bg);border:1px solid var(--border);
  color:var(--t2);font-size:12px;font-weight:600;
  padding:7px 16px;border-radius:8px;cursor:pointer;
  transition:border-color .12s,background .12s;
}
.step-nav-btn:hover{border-color:var(--blue);color:var(--blue);background:var(--blue-l)}
.step-nav-next{background:var(--blue);border-color:var(--blue);color:#fff}
.step-nav-next:hover{background:#2563eb;border-color:#2563eb;color:#fff}
.step-nav-info{font-size:11px;color:var(--t4)}

/* placeholder still usable */
.step-placeholder{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:10px;padding:40px 20px;color:var(--t3);text-align:center;
}
.step-placeholder-icon{font-size:36px;opacity:.5}
.step-placeholder-title{font-size:13px;font-weight:700;color:var(--t2)}
.step-placeholder-sub{font-size:11px;color:var(--t4);max-width:360px}

/* ══════════════════════════════════════════════
   STAGE 6-7 CSS — Methodology Badges, Tables,
   HITL Approve, ReAct Log, vis.js Graph
══════════════════════════════════════════════ */

/* ── Step section divider ── */
.step-section{margin-bottom:22px}
.step-section-title{
  font-size:10px;font-weight:700;
  text-transform:uppercase;letter-spacing:.5px;
  color:var(--t3);padding-bottom:7px;margin-bottom:11px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:6px;
}

/* ── Methodology Badges ── */
.mbadge-wrap{display:flex;flex-wrap:wrap;gap:7px;margin-top:16px;padding-top:14px;border-top:1px dashed var(--border)}
.mbadge{
  display:inline-flex;align-items:flex-start;flex-wrap:wrap;gap:3px;
  padding:5px 10px;border-radius:7px;
  font-size:10px;font-weight:600;line-height:1.5;
}
.mbadge-green{background:var(--green-l);color:var(--green);border:1px solid rgba(22,163,74,.2)}
.mbadge-red{background:rgba(239,68,68,.07);color:#dc2626;border:1px solid rgba(239,68,68,.2)}
.mbadge-amber{background:rgba(245,158,11,.08);color:#d97706;border:1px solid rgba(245,158,11,.2)}
.mbadge-blue{background:var(--blue-l);color:var(--blue);border:1px solid rgba(37,99,235,.15)}
.mbadge-purple{background:rgba(124,58,237,.07);color:#7c3aed;border:1px solid rgba(124,58,237,.2)}
.mb-sep{color:var(--t4);font-weight:400;margin:0 1px}
.mb-val{font-family:ui-monospace,monospace;font-size:9px;opacity:.85}

/* ── Data tables ── */
.step-table-wrap{overflow-x:auto;margin:10px 0;border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden}
.step-table{width:100%;border-collapse:collapse;font-size:12px}
.step-table th{
  background:var(--bg2);color:var(--t3);
  font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;
  padding:8px 12px;text-align:left;
  border-bottom:2px solid var(--border);white-space:nowrap;
}
.step-table td{
  padding:9px 12px;border-bottom:1px solid var(--border);
  color:var(--t2);vertical-align:top;font-size:12px;line-height:1.4;
}
.step-table tr:last-child td{border-bottom:none}
.step-table tr:hover td{background:var(--bg2)}
.td-ok {color:var(--green);font-weight:700}
.td-err{color:var(--red);font-weight:700}
.td-warn{color:var(--amber);font-weight:700}
.td-code{font-family:ui-monospace,monospace;font-size:10px;color:var(--blue)}
.td-sigma{font-size:13px;font-weight:800;color:var(--red)}
.td-hi{background:rgba(239,68,68,.05)}
.td-pct{font-weight:700}

/* Priority rows */
.pr-p0{border-left:3px solid var(--red)}
.pr-p1{border-left:3px solid var(--amber)}
.pr-p2{border-left:3px solid var(--green)}
.pri-chip{display:inline-block;padding:1px 7px;border-radius:10px;font-size:10px;font-weight:700}
.pri-p0{background:rgba(239,68,68,.1);color:var(--red)}
.pri-p1{background:rgba(245,158,11,.1);color:var(--amber)}
.pri-p2{background:var(--green-l);color:var(--green)}

/* Entity type chip */
.entity-chip{display:inline-block;padding:2px 7px;border-radius:8px;font-size:10px;font-weight:600}
.etype-person{background:rgba(139,92,246,.1);color:var(--purple)}
.etype-company{background:var(--blue-l);color:var(--blue)}
.etype-contract{background:rgba(245,158,11,.1);color:var(--amber)}

/* ── HITL Approve Box ── */
.hitl-approve-box{
  background:linear-gradient(135deg,rgba(245,158,11,.07),rgba(245,158,11,.02));
  border:2px dashed var(--amber);
  border-radius:var(--r-lg);padding:20px 22px;
  margin:16px 0;
}
.hitl-approve-box.approved{
  background:linear-gradient(135deg,rgba(22,163,74,.07),rgba(22,163,74,.02));
  border-color:var(--green);
}
.hitl-approve-title{font-size:13px;font-weight:700;color:var(--t1);margin-bottom:5px}
.hitl-approve-sub{font-size:11px;color:var(--t3);margin-bottom:10px;line-height:1.7}
.hitl-approve-meta{font-size:10px;color:var(--t4);margin-bottom:14px;
  background:var(--bg3);padding:8px 12px;border-radius:6px;line-height:1.6}
.hitl-approve-btn{
  background:var(--amber);color:#fff;border:none;
  padding:10px 24px;border-radius:8px;
  font-size:12px;font-weight:700;cursor:pointer;
  transition:background .15s,transform .1s;
  animation:pulse-amber 2s infinite;
}
.hitl-approve-btn:hover{background:#b45309;transform:scale(1.02)}
.hitl-approve-btn:disabled{background:var(--green);animation:none;cursor:default}
@keyframes pulse-amber{
  0%,100%{box-shadow:0 0 0 0 rgba(245,158,11,.4)}
  50%{box-shadow:0 0 0 8px rgba(245,158,11,0)}
}

/* ── ReAct Inline Log ── */
.react-inline-log{
  background:var(--bg2);border:1px solid var(--border);
  border-radius:8px;padding:12px 14px;margin:12px 0;
}
.rle{margin-bottom:10px;padding-left:12px;border-left:2px solid var(--border)}
.rle:last-child{margin-bottom:0}
.rle.thought{border-color:var(--purple)}
.rle.action {border-color:var(--blue)}
.rle.obs    {border-color:var(--green)}
.rle-label{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px}
.rle.thought .rle-label{color:var(--purple)}
.rle.action  .rle-label{color:var(--blue)}
.rle.obs     .rle-label{color:var(--green)}
.rle-text{font-size:11px;color:var(--t2);line-height:1.65}
.rle-text code{
  font-family:ui-monospace,monospace;font-size:10px;
  background:var(--bg3);padding:1px 4px;border-radius:3px;color:var(--blue);
}

/* ── vis.js Knowledge Graph ── */
.vis-graph-toolbar{display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap}
.vis-layout-btn{
  padding:5px 14px;border-radius:7px;
  border:1px solid var(--border);
  background:var(--bg);color:var(--t3);
  font-size:11px;font-weight:600;cursor:pointer;
  transition:all .12s;
}
.vis-layout-btn.vl-active,.vis-layout-btn:hover{
  border-color:var(--blue);color:var(--blue);background:var(--blue-l)
}
.vis-graph-container{
  width:100%;height:360px;
  border:1px solid var(--border);border-radius:var(--r-lg);
  background:var(--bg2);overflow:hidden;
  position:relative;
}
.vis-legend{
  display:flex;flex-wrap:wrap;gap:12px;
  font-size:10px;color:var(--t3);margin-top:10px;
}
.vis-legend-item{display:flex;align-items:center;gap:5px}
.vis-dot{width:11px;height:11px;border-radius:50%;display:inline-block;flex-shrink:0}
.vdot-risk{background:#dc2626}
.vdot-normal{background:#94a3b8}
.vdot-company{background:#2563eb}
.vdot-contract{background:#7c3aed}
.vdot-edge{background:#dc2626;width:18px;height:2px;border-radius:0}
.vis-louvain-note{
  font-size:11px;color:var(--t3);line-height:1.6;
  margin-top:10px;padding:8px 12px;
  background:rgba(239,68,68,.05);border-radius:6px;
  border-left:3px solid var(--red);
}

/* ══════════════════════════════════════════════
   STAGE 8 CSS — Step 7 Statistical + Behavioral
══════════════════════════════════════════════ */

/* ── Parallel execution banner ── */
.parallel-banner{
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;
  background:linear-gradient(90deg,var(--blue-l),var(--bg2));
  border:1px solid rgba(37,99,235,.2);border-radius:8px;
  padding:9px 14px;margin-bottom:16px;font-size:11px;
}
.pb-label{font-weight:700;color:var(--blue);white-space:nowrap}
.pb-agents{display:flex;gap:8px;flex-wrap:wrap}
.pb-agent{
  display:flex;align-items:center;gap:5px;
  padding:3px 10px;border-radius:20px;
  background:var(--bg);border:1px solid var(--border);
  font-size:11px;font-weight:600;color:var(--t2);
}
.pb-done{border-color:var(--green);color:var(--t2)}
.pb-check{color:var(--green);font-weight:700}
.pb-ref{margin-left:auto;font-size:10px;color:var(--t4);white-space:nowrap}

/* ── Agent section header (7a / 7b divider) ── */
.agent-section-head{
  display:flex;align-items:center;gap:10px;
  padding:10px 14px;border-radius:8px;
  margin-bottom:14px;
}
.ash-stat{background:linear-gradient(90deg,rgba(239,68,68,.07),var(--bg2));border:1px solid rgba(239,68,68,.15)}
.ash-behav{background:linear-gradient(90deg,rgba(245,158,11,.07),var(--bg2));border:1px solid rgba(245,158,11,.15);margin-top:22px}
.ash-icon{font-size:22px;flex-shrink:0}
.ash-name{font-size:13px;font-weight:700;color:var(--t1)}
.ash-sub{font-size:10px;color:var(--t3);margin-top:2px}

/* ── Sigma callout cards ── */
.sigma-cards{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(155px,1fr));
  gap:10px;margin:10px 0 16px;
}
.sigma-card{
  background:rgba(239,68,68,.05);
  border:1px solid rgba(239,68,68,.2);
  border-radius:10px;padding:14px 12px;
  text-align:center;position:relative;
}
.sigma-card-id{font-size:10px;font-weight:700;color:var(--t3);margin-bottom:2px}
.sigma-card-product{font-size:10px;color:var(--t4);margin-bottom:8px}
.sigma-card-formula{
  font-size:10px;color:var(--t4);
  font-family:ui-monospace,monospace;
  margin-bottom:6px;line-height:1.4;
}
.sigma-card-val{
  font-size:32px;font-weight:900;color:var(--red);
  line-height:1;margin-bottom:4px;
  font-variant-numeric:tabular-nums;
}
.sigma-card-sublabel{font-size:10px;color:var(--red);opacity:.7;font-weight:600}

/* Behavior sigma cards (smaller, 3-per-row) */
.sigma-cards-behav{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(130px,1fr));
  gap:8px;margin:10px 0 14px;
}
.sigma-card-behav{
  background:rgba(245,158,11,.05);
  border:1px solid rgba(245,158,11,.2);
  border-radius:8px;padding:10px 10px;
  text-align:center;
}
.scb-dim{font-size:10px;color:var(--t3);font-weight:600;margin-bottom:4px}
.scb-val{font-size:22px;font-weight:900;line-height:1;margin-bottom:2px;font-variant-numeric:tabular-nums}
.scb-val-red{color:var(--red)}
.scb-val-amber{color:var(--amber)}
.scb-formula{font-size:9px;color:var(--t4);line-height:1.4}

/* Three-way match status chips */
.twm-chip{display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:700}
.twm-ok{background:var(--green-l);color:var(--green)}
.twm-err{background:rgba(239,68,68,.1);color:var(--red)}
.twm-warn{background:rgba(245,158,11,.1);color:var(--amber)}

/* 7b false positive table */
.fp-tag{display:inline-block;padding:1px 7px;border-radius:8px;font-size:10px;font-weight:600}
.fp-excluded{background:var(--green-l);color:var(--green)}
.fp-flagged{background:rgba(245,158,11,.1);color:var(--amber)}

/* ══════════════════════════════════════════════
   STAGE 9 CSS — Steps 8-12
══════════════════════════════════════════════ */

/* ── Confidence calculation box (Step 8) ── */
.conf-calc-box{
  background:linear-gradient(135deg,var(--blue-l),var(--bg2));
  border:1px solid rgba(37,99,235,.2);border-radius:var(--r-lg);
  padding:18px 20px;margin:12px 0;
}
.ccb-title{font-size:11px;font-weight:700;color:var(--blue);margin-bottom:12px;text-transform:uppercase;letter-spacing:.4px}
.conf-calc-row{
  display:grid;grid-template-columns:1fr 130px 20px 60px;
  align-items:center;gap:8px;
  padding:6px 0;border-bottom:1px dashed var(--border);font-size:12px;
}
.ccr-label{color:var(--t2);font-weight:600}
.ccr-formula{font-family:ui-monospace,monospace;font-size:11px;color:var(--blue);text-align:right}
.ccr-eq{color:var(--t4);text-align:center}
.ccr-val{font-family:ui-monospace,monospace;font-weight:700;color:var(--t2);text-align:right}
.conf-calc-total{
  display:grid;grid-template-columns:1fr 130px 20px 60px;
  align-items:center;gap:8px;
  padding:8px 0 0;font-size:13px;font-weight:700;
}
.conf-calc-total span:first-child{color:var(--t1)}
.conf-calc-total span:nth-child(2){font-family:ui-monospace,monospace;font-size:11px;color:var(--t3);text-align:right}
.conf-calc-total span:nth-child(3){color:var(--t4);text-align:center}
.cct-result{font-size:24px;font-weight:900;color:var(--blue);text-align:right}
.ccb-note{font-size:10px;color:var(--t4);margin-top:8px;font-style:italic}

/* Cross-validation chips */
.cv-chip{display:inline-flex;align-items:center;gap:3px;font-size:10px;padding:2px 6px;border-radius:6px;font-weight:600;line-height:1.5}
.cv-yes{background:var(--green-l);color:var(--green)}
.cv-no{background:var(--bg3);color:var(--t4)}
.verify-2{background:rgba(245,158,11,.1);color:var(--amber);font-weight:700;padding:2px 8px;border-radius:8px;font-size:10px}
.verify-3{background:rgba(239,68,68,.1);color:var(--red);font-weight:700;padding:2px 8px;border-radius:8px;font-size:10px}

/* ── Hypothesis stepper (Step 9) ── */
.hyp-stepper{
  display:grid;grid-template-columns:1fr 28px 1fr 28px 1fr;
  align-items:start;gap:4px;margin:12px 0;
}
.hyp-arrow{font-size:18px;color:var(--t4);align-self:center;text-align:center;padding-top:18px}
.hyp-round-card{
  background:var(--bg2);border:1px solid var(--border);border-radius:10px;
  padding:12px 12px;
}
.hrc-badge{
  display:inline-block;padding:2px 8px;border-radius:10px;
  font-size:10px;font-weight:700;margin-bottom:6px;
}
.hrc-r1{background:rgba(99,102,241,.1);color:#6366f1}
.hrc-r2{background:rgba(245,158,11,.1);color:var(--amber)}
.hrc-r3{background:var(--blue-l);color:var(--blue)}
.hrc-input{font-size:10px;color:var(--t3);margin-bottom:10px;line-height:1.5;min-height:28px}
.hrc-hyp{margin-bottom:6px}
.hrc-hyp-label{font-size:10px;color:var(--t3);margin-bottom:2px;font-weight:600}
.hrc-bar-wrap{display:flex;align-items:center;gap:6px}
.hrc-bar{height:5px;border-radius:3px;flex:1;background:var(--bg3);overflow:hidden}
.hrc-bar-fill{height:100%;border-radius:3px;transition:width .4s}
.hrc-pct{font-size:11px;font-weight:700;min-width:30px;text-align:right}
.hrc-h1 .hrc-bar-fill,.hrc-h1-final .hrc-bar-fill{background:var(--blue)}
.hrc-h1-final .hrc-bar-fill{background:var(--green)}
.hrc-h1 .hrc-pct{color:var(--blue)}
.hrc-h1-final .hrc-pct{color:var(--green)}
.hrc-h2 .hrc-bar-fill{background:var(--amber)}
.hrc-h2 .hrc-pct{color:var(--amber)}
.hrc-h3 .hrc-bar-fill{background:var(--t4)}
.hrc-h3 .hrc-pct{color:var(--t4)}

/* Devil's advocate box */
.devils-box{
  background:rgba(124,58,237,.05);border:1px solid rgba(124,58,237,.2);
  border-radius:var(--r-lg);padding:14px 16px;margin:12px 0;
}
.devils-title{font-size:11px;font-weight:700;color:var(--purple);margin-bottom:10px}
.devils-row{
  display:grid;grid-template-columns:1fr 1fr;gap:10px;
  margin-bottom:8px;font-size:12px;padding-bottom:8px;
  border-bottom:1px dashed var(--border);
}
.devils-row:last-child{border-bottom:none;margin-bottom:0}
.devils-q{color:var(--t3);font-style:italic;line-height:1.5}
.devils-a{color:var(--t2);line-height:1.5}

/* ── Interview questions (Step 10) ── */
.interview-round-head{
  display:flex;align-items:center;gap:8px;
  padding:8px 12px;border-radius:8px;
  background:var(--bg2);border:1px solid var(--border);
  margin:14px 0 8px;
}
.irh-badge{padding:3px 10px;border-radius:10px;font-size:10px;font-weight:700}
.irh-r1{background:var(--blue-l);color:var(--blue)}
.irh-r2{background:rgba(245,158,11,.1);color:var(--amber)}
.irh-r3{background:rgba(239,68,68,.1);color:var(--red)}
.irh-desc{font-size:11px;color:var(--t3)}
.interview-q{
  padding:9px 14px;background:var(--bg);border:1px solid var(--border);
  border-radius:7px;margin-bottom:7px;
  font-size:12px;color:var(--t2);line-height:1.7;
  border-left:3px solid var(--blue);
}
.interview-q.round2{border-left-color:var(--amber)}
.interview-q.round3{border-left-color:var(--red);font-weight:600}
.interview-note{
  font-size:10px;color:var(--t4);
  background:var(--bg2);padding:9px 12px;border-radius:6px;
  margin-top:12px;line-height:1.7;border-left:3px solid var(--border);
}
.iq-tech{
  display:inline-block;font-size:9px;font-weight:700;letter-spacing:.3px;
  padding:1px 6px;border-radius:4px;margin-right:7px;vertical-align:middle;
  background:rgba(37,99,235,.1);color:var(--blue);border:1px solid rgba(37,99,235,.2);
}
.iq-tech.t-amber{background:rgba(245,158,11,.1);color:var(--amber);border-color:rgba(245,158,11,.25)}
.iq-tech.t-red{background:rgba(220,38,38,.1);color:var(--red);border-color:rgba(220,38,38,.25)}

/* ── Report generation (Step 11) ── */
.report-sections{display:flex;flex-direction:column;gap:6px;margin:12px 0}
.rsl-item{
  display:flex;align-items:center;gap:10px;
  padding:9px 14px;border:1px solid var(--border);border-radius:8px;
  font-size:12px;background:var(--bg);
}
.rsl-num{
  width:24px;height:24px;border-radius:50%;
  background:var(--green);color:#fff;
  display:flex;align-items:center;justify-content:center;
  font-size:10px;font-weight:700;flex-shrink:0;
}
.rsl-name{flex:1;font-weight:600;color:var(--t1)}
.rsl-sub{font-size:10px;color:var(--t3)}
.rsl-check{color:var(--green);font-weight:700;font-size:14px}
.fin-impact-box{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:12px 0}
.fib-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:12px;text-align:center}
.fib-label{font-size:10px;color:var(--t3);margin-bottom:4px}
.fib-val{font-size:20px;font-weight:800}
.fib-val-red{color:var(--red)}
.fib-val-green{color:var(--green)}
.fib-sub{font-size:10px;color:var(--t4);margin-top:3px}

/* ── Disposition matrix (Step 12) ── */
.disp-recommended td{background:rgba(22,163,74,.05)!important}
.disp-curr-badge{
  display:inline-block;padding:2px 9px;border-radius:8px;
  background:var(--green);color:#fff;font-size:10px;font-weight:700;
}
.disp-na{color:var(--t4);font-size:11px}

/* ── Right evidence panel ── */
.case-evidence{
  background:var(--bg);border-left:1px solid var(--border);
  overflow-y:auto;
  padding:14px 14px 24px;
}
.evi-section{margin-bottom:18px}
.evi-section-title{
  font-size:10px;font-weight:700;color:var(--t3);
  text-transform:uppercase;letter-spacing:.6px;
  padding-bottom:6px;margin-bottom:8px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:5px;
}
.evi-section-title .count-chip{
  margin-left:auto;background:var(--bg3);color:var(--t2);
  font-size:9px;padding:1px 6px;border-radius:8px;font-weight:600;
}
.evi-item{
  padding:7px 9px;border:1px solid var(--border);
  border-radius:5px;margin-bottom:5px;
  font-size:11px;cursor:pointer;
  transition:border-color .12s,background .12s;
}
.evi-item:hover{border-color:var(--blue);background:var(--blue-l)}
.evi-item-id{
  font-family:ui-monospace,'SF Mono',monospace;
  font-size:10px;color:var(--blue);font-weight:700;
}
.evi-item-desc{color:var(--t2);margin-top:2px;line-height:1.4}
.evi-item-hash{
  font-family:ui-monospace,monospace;
  font-size:9px;color:var(--t4);margin-top:3px;
}

/* Confidence gauge */
.conf-gauge{
  background:var(--bg2);border:1px solid var(--border);
  border-radius:8px;padding:12px;text-align:center;
}
.conf-gauge-val{
  font-size:32px;font-weight:800;letter-spacing:-.5px;
  color:var(--red);line-height:1;margin-bottom:4px;
}
.conf-gauge-label{font-size:10px;color:var(--t3);margin-bottom:8px}
.conf-bar{
  height:6px;background:var(--bg3);border-radius:3px;overflow:hidden;
  margin-bottom:8px;
}
.conf-bar-fill{
  height:100%;
  background:linear-gradient(90deg,var(--amber),var(--red));
  border-radius:3px;
}
.conf-sources{display:flex;flex-direction:column;gap:4px;margin-top:6px}
.conf-source{
  display:flex;align-items:center;justify-content:space-between;
  font-size:10px;color:var(--t2);
}
.conf-source-dot{
  width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-right:6px;
}

/* ══════════════════════════════════════════════
   AGENT MODAL — STAGE 4 CONTENT STYLES
══════════════════════════════════════════════ */

/* Widen modal box for 2-col layout */
#agent-modal-box{max-width:940px}

/* 2-column body grid */
.modal-2col{
  display:grid;
  grid-template-columns:1fr 340px;
  gap:24px;
}
.m-left{display:flex;flex-direction:column;gap:18px}
.m-right{display:flex;flex-direction:column;gap:14px}

/* Section block */
.m-section{}
.m-section-title{
  font-size:10px;font-weight:700;letter-spacing:.6px;
  text-transform:uppercase;color:var(--t3);
  margin-bottom:9px;padding-bottom:6px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:5px;
}
.m-section-title small{
  font-weight:400;text-transform:none;letter-spacing:0;color:var(--t4);font-size:9px;
}

/* Tagline */
.m-tagline{
  font-size:13px;font-weight:700;color:var(--t1);
  line-height:1.6;padding:13px 16px;
  background:var(--bg2);border-radius:var(--r);
  border-left:3px solid var(--blue);
}

/* Ability list */
.m-abilities{display:flex;flex-direction:column;gap:7px}
.m-ability{
  display:flex;align-items:flex-start;gap:8px;
  padding:8px 10px;border-radius:6px;
  background:var(--bg2);font-size:11px;color:var(--t2);line-height:1.55;
}
.m-ability-dot{
  width:5px;height:5px;border-radius:50%;
  background:var(--blue);flex-shrink:0;margin-top:5px;
}
.m-ability code{
  font-family:ui-monospace,'SF Mono',monospace;
  font-size:9px;background:var(--bg3);
  padding:1px 4px;border-radius:3px;color:var(--t1);
}
.m-ability-cite{
  font-size:9px;color:var(--t4);
  font-family:ui-monospace,monospace;margin-left:3px;
}

/* ReAct log */
.react-log{display:flex;flex-direction:column;gap:5px}
.react-step{border:1px solid var(--border);border-radius:6px;overflow:hidden;font-size:11px}
.react-step-head{
  padding:4px 10px;
  font-size:9px;font-weight:700;letter-spacing:.3px;
  display:flex;align-items:center;gap:5px;
  background:var(--bg2);color:var(--t3);
}
.rs-thought .react-step-head{background:var(--purple-l);color:var(--purple)}
.rs-action  .react-step-head{background:var(--blue-l);color:var(--blue)}
.rs-obs     .react-step-head{background:var(--green-l);color:var(--green)}
html[data-theme="dark"] .rs-thought .react-step-head{background:var(--purple-m)}
html[data-theme="dark"] .rs-action  .react-step-head{background:var(--blue-m)}
html[data-theme="dark"] .rs-obs     .react-step-head{background:var(--green-m)}
.react-step-body{
  padding:7px 10px;color:var(--t2);line-height:1.6;
}
.react-step-body code{
  font-family:ui-monospace,'SF Mono',monospace;
  font-size:9px;background:var(--bg3);padding:1px 4px;
  border-radius:3px;color:var(--t1);word-break:break-all;
}

/* Interaction list */
.interact-list{display:flex;flex-direction:column;gap:5px}
.interact-item{
  display:flex;align-items:flex-start;gap:7px;
  padding:6px 10px;border-radius:6px;
  border:1px solid var(--border);font-size:11px;
}
.interact-dir{
  font-size:9px;font-weight:700;padding:1px 6px;border-radius:3px;
  flex-shrink:0;margin-top:1px;white-space:nowrap;
}
.interact-in {background:var(--blue-m);color:var(--blue)}
.interact-out{background:var(--green-m);color:var(--green)}
.interact-text{color:var(--t2);line-height:1.5}

/* Step badges */
.step-badge-list{display:flex;flex-wrap:wrap;gap:5px}
.step-badge{
  font-size:10px;font-weight:600;padding:3px 9px;border-radius:4px;
  background:var(--bg3);color:var(--t2);border:1px solid var(--border);
}

/* Tool list */
.tool-list{display:flex;flex-direction:column;gap:4px}
.tool-item{
  display:flex;align-items:flex-start;gap:7px;
  padding:5px 8px;border-radius:5px;background:var(--bg2);
}
.tool-item code{
  font-family:ui-monospace,'SF Mono',monospace;
  font-size:10px;color:var(--blue);font-weight:600;
  white-space:nowrap;flex-shrink:0;
}
.tool-desc{color:var(--t3);font-size:10px;line-height:1.4;padding-top:1px}

/* IO Schema box */
.schema-label{
  font-size:9px;font-weight:700;color:var(--t3);
  letter-spacing:.4px;text-transform:uppercase;
  margin-bottom:4px;
}
.schema-box{
  background:var(--bg3);border:1px solid var(--border);
  border-radius:5px;padding:8px 10px;
  font-family:ui-monospace,'SF Mono',monospace;
  font-size:9.5px;line-height:1.65;color:var(--t2);
  white-space:pre;overflow-x:auto;
}

/* HITL explain */
.hitl-explain-box{
  border-radius:6px;padding:10px 12px;
  font-size:11px;line-height:1.55;
}
.hitl-1-box{background:var(--red-l);border:1px solid #fca5a5;color:#991b1b}
.hitl-2-box{background:var(--amber-l);border:1px solid #fcd34d;color:#92400e}
.hitl-3-box{background:var(--green-l);border:1px solid #6ee7b7;color:#065f46}
html[data-theme="dark"] .hitl-1-box{background:var(--red-m);color:#fca5a5}
html[data-theme="dark"] .hitl-2-box{background:var(--amber-m);color:#fcd34d}
html[data-theme="dark"] .hitl-3-box{background:var(--green-m);color:#6ee7b7}
.hitl-explain-title{font-weight:700;margin-bottom:5px}

/* Modal footer (injected inside modal-body, bleeds to edges) */
.modal-footer{
  margin:20px -20px -20px;
  padding:12px 20px;
  border-top:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  background:var(--bg2);gap:12px;flex-wrap:wrap;
}
.modal-footer-info{font-size:10px;color:var(--t3);display:flex;align-items:center;gap:6px;flex-wrap:wrap}

/* Right-column divider on small screens */
@media(max-width:760px){
  .modal-2col{grid-template-columns:1fr}
  .m-left{border-right:none;padding-right:0}
}

/* ══════════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════════ */
@media(max-width:768px){
  #nav{padding:0 16px}
  .nav-demo-badge{display:none}
  .hero-title{font-size:28px}
  .agent-cards-grid{grid-template-columns:1fr}
  .agent-card.card-full{grid-column:1}
  .org-chart-section,.agent-cards-section{padding-left:16px;padding-right:16px}
  .case-card{flex-direction:column}
  .case-card-field{border-right:none;border-bottom:1px solid var(--border)}
  .case-card-field:last-child{border-bottom:none}
}
</style>
</head>
<body>

<!-- ══════════════════════════════════════════════
     TOP NAVIGATION
════════════════════════════════════════════════ -->
<nav id="nav">
  <div class="nav-logo" onclick="showView('home')">
    <div class="nav-logo-box">MT</div>
    <div>
      <div class="nav-logo-name">MultiTrace</div>
      <div class="nav-logo-sub">AI Investigation Platform</div>
    </div>
  </div>

  <div class="nav-links">
    <button class="nav-link active" id="nav-home" onclick="showView('home')">主页</button>
    <button class="nav-link" id="nav-case" onclick="showView('case')">示范案例 →</button>
  </div>

  <div class="nav-spacer"></div>

  <div class="nav-demo-badge">
    <div class="nav-demo-dot"></div>
    Demo Mode · INV-2024-0847
  </div>

  <button class="nav-theme-btn" onclick="toggleTheme()">
    <span id="theme-icon">🌙</span>
    <span id="theme-text">深色模式</span>
  </button>
</nav>

<!-- ══════════════════════════════════════════════
     VIEW: HOME
════════════════════════════════════════════════ -->
<div class="view active" id="view-home">

  <!-- ── Hero ── -->
  <div class="home-hero">
    <div class="hero-eyebrow">
      🤖 基于 LangGraph 的 7-Agent 协作架构
    </div>
    <h1 class="hero-title">
      <span class="hero-title-grad">AI Agent 团队</span>驱动的<br>企业反腐败调查平台
    </h1>
    <p class="hero-sub">
      MultiTrace 部署 7 个专职 AI Agent，自动完成<strong style="color:var(--t1)">企业内部调查</strong>中的数据摄取、证据图谱构建、统计异常检测、行为模式分析与多证据交叉印证，
      将分析管线从传统 <strong style="color:var(--red)">30–45 个工作日</strong>压缩至 <strong style="color:var(--green)">4–8 小时</strong>。
      调查员专注于立案授权、假设确认、处置移交 3 个核心决策节点，所有结论须经专业人员审查签发，具备完整合规审查链，可作为纪律处分与司法移交的证据基础。
    </p>
